# ============================================================
# FRONTEND — Variáveis de Ambiente
# INSTRUÇÕES: Copie este arquivo para .env e preencha os valores
# ============================================================

# URL pública do seu painel (o mesmo domínio do frontend)
# O nginx vai redirecionar /api/* para o backend automaticamente
# Exemplo: https://dashboard.maringa.pr.gov.br
VITE_API_URL=https://seu-dominio-aqui.com

# Supabase (opcional — só se o frontend acessar o Supabase diretamente)
# Encontre em: supabase.com → seu projeto → Settings → API → anon key
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
