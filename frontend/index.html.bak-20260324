/* Busca dados da API a cada 5 segundos — faz o dashboard atualizar sozinho */
function useApiPolling(){
  const [tick,setTick]=useState(0);
  useEffect(()=>{
    async function poll(){
      try{
        const [oc,den,sos,fb,kpis,recomp,rkpis,rcfg,soshist,reldata]=await Promise.all([
          fetch(API_URL+'/api/ocorrencias/').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/denuncias/').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/sos/alertas/ativos').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/feedbacks/').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/kpis').then(r=>r.ok?r.json():{}).catch(()=>({})),
          fetch(API_URL+'/api/recompensas/').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/recompensas/kpis').then(r=>r.ok?r.json():{}).catch(()=>({})),
          fetch(API_URL+'/api/recompensas/config').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/sos/alertas/historico').then(r=>r.ok?r.json():[]).catch(()=>[]),
          fetch(API_URL+'/api/relatorio').then(r=>r.ok?r.json():null).catch(()=>null),
        ]);
        OC=oc.map(o=>({...o,lat:o.latitude,lng:o.longitude}));
        DEN=den.map(d=>({...d,lat:d.latitude,lng:d.longitude}));
        SOS=sos.map(s=>({...s,lat:s.latitude,lng:s.longitude}));
        SOS_HIST=soshist;
        if(reldata) REL_DATA=reldata;
        FBK=fb.map(f=>{
          const priMap={alta:'critico',normal:'urgente',baixa:'normal'};
          const catMap={transporte:'transporte',saude:'saude_atendimento',educacao:'educacao_escolas',
            seguranca:'seguranca_publica',infraestrutura:'infraestrutura_obras',
            meio_ambiente:'limpeza_urbana',cultura_lazer:'transporte',
            atendimento_publico:'saude_atendimento',outros:'infraestrutura_obras'};
          return{...f,lat:f.latitude,lng:f.longitude,
            prioridade:priMap[f.urgencia]||'normal',
            categoria:catMap[f.categoria]||f.categoria,
            status:f.status==='novo'?'aberto':f.status};
        });
        KPIS=kpis;
        RECOMP=recomp; RECOMP_KPIS=rkpis; RECOMP_CFG=rcfg;
        setTick(t=>t+1);
      }catch(e){console.error('API poll error:',e);}
    }
    poll();
    const i=setInterval(poll,5000);
    return()=>clearInterval(i);
  },[]);
  return tick;
}

