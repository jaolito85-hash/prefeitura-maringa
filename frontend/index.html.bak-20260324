<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Node Data — Central de Segurança Pública · Maringá-PR</title>
<script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
<script src="https://unpkg.com/@babel/standalone@7.23.5/babel.min.js" crossorigin></script>
<script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>
<link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Public+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#050507;
  --surface:#0b0c10;
  --card:#111217;
  --card-hover:#1c1e26;
  --border:#23252e;
  --border-light:#2d3039;
  --accent:#059669;
  --accent-light:#34d399;
  --accent-bg:rgba(5,150,105,.08);
  --blue:#3b82f6;
  --cyan:#3b82f6;
  --text:#ffffff;
  --text-secondary:#d1d5db;
  --text-muted:#8b949e;
  --danger:#ef4444;
  --danger-light:#fca5a5;
  --warn:#f59e0b;
  --warn-light:#fcd34d;
  --success:#22c55e;
  --success-light:#34d399;
  --purple:#a855f7;
  --radius:12px;
}
html,body,#root{height:100%;background:var(--bg);color:var(--text);overflow:hidden}
body{font-family:'Public Sans','Inter',sans-serif;font-size:14px;font-weight:400;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-light);border-radius:4px}
.app{display:flex;flex-direction:column;height:100vh}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:56px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;position:relative;z-index:20}
.logo{display:flex;align-items:center;gap:12px}
.logo-mark{width:32px;height:32px}
.logo-text{font-size:18px;font-weight:700;color:#fff;letter-spacing:-.2px}
.logo-text span{font-weight:400;color:var(--accent-light);margin-left:1px}
.logo-sep{width:1px;height:20px;background:var(--border-light);margin:0 16px}
.logo-sub{font-size:13px;color:var(--text-secondary);font-weight:400}
.hdr-right{display:flex;align-items:center;gap:20px}
.status-badge{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:var(--success-light);padding:4px 10px;background:rgba(5,150,105,.1);border:1px solid rgba(5,150,105,.2);border-radius:20px}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--success-light);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.clock-area{text-align:right}
.clock{font-family:'Public Sans',sans-serif;font-weight:700;font-size:18px;font-weight:600;color:#fff;letter-spacing:.5px}
.clock-date{font-size:11px;color:var(--text-muted);margin-top:1px;text-transform:capitalize}
.hdr-btn{background:var(--card);border:1px solid var(--border);color:var(--text-secondary);width:36px;height:36px;border-radius:8px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.hdr-btn:hover{border-color:var(--border-light);color:var(--text)}

/* SOS BANNER */
.sos-banner{display:flex;align-items:center;gap:14px;padding:10px 24px;background:#991b1b;cursor:pointer;flex-shrink:0;transition:background .2s}
.sos-banner:hover{background:#b91c1c}
.sos-label{font-weight:700;font-size:13px;letter-spacing:.5px;text-transform:uppercase}
.sos-detail{font-size:13px;opacity:.9;margin-left:8px}
.sos-count{margin-left:auto;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:20px;padding:3px 14px;font-size:12px;font-weight:600}

/* BODY */
.body{display:flex;flex:1;overflow:hidden}

/* SIDEBAR */
.sidebar{width:260px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:16px 12px;flex-shrink:0}
.sidebar-section{font-size:10px;color:var(--text-muted);font-weight:600;letter-spacing:1.2px;text-transform:uppercase;padding:8px 12px 6px;margin-top:4px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--radius);cursor:pointer;color:var(--text-secondary);font-size:13.5px;font-weight:500;border:1px solid transparent;margin-bottom:2px;transition:all .15s;user-select:none;background:none}
.nav-item:hover{background:var(--card-hover);color:var(--text)}
.nav-item.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.nav-icon{width:18px;height:18px;flex-shrink:0;opacity:.7}
.nav-item.active .nav-icon{opacity:1}
.nav-badge{margin-left:auto;background:var(--danger);color:#fff;border-radius:10px;padding:1px 8px;font-size:11px;font-weight:600}
.nav-divider{height:1px;background:var(--border);margin:12px 8px}
.ws-row{display:flex;align-items:center;gap:8px;padding:4px 12px;font-size:12px;color:var(--text-muted)}
.ws-dot{width:5px;height:5px;border-radius:50%;background:var(--success-light);flex-shrink:0}

/* CONTENT */
.content{flex:1;overflow:hidden;display:flex;flex-direction:column;background:var(--bg)}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius)}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;padding:20px;flex-shrink:0}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px;transition:.2s}
.kpi:hover{border-color:rgba(5,150,105,.3)}
.kpi-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.kpi-label{font-size:12px;color:var(--text-muted);font-weight:500;text-transform:uppercase;letter-spacing:.5px}
.kpi-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}
.kpi-value{font-family:'Public Sans',sans-serif;font-weight:700;font-size:32px;font-weight:600;line-height:1;color:#fff}
.kpi-sub{font-size:11px;color:var(--text-muted);margin-top:6px}

/* TABLES */
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:12px 16px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text-muted);border-bottom:1px solid var(--border);background:var(--card)}
td{padding:14px 16px;border-bottom:1px solid var(--border);vertical-align:middle;font-size:13.5px;color:var(--text-secondary)}
tr{transition:background .1s}
tr:hover td{background:rgba(255,255,255,.02)}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px;font-size:12px;font-weight:500}
.b-blue{background:rgba(59,130,246,.1);color:var(--blue);border:1px solid rgba(59,130,246,.2)}
.b-red{background:rgba(220,38,38,.1);color:#f87171;border:1px solid rgba(220,38,38,.2)}
.b-warn{background:rgba(251,191,36,.1);color:#fbbf24;border:1px solid rgba(251,191,36,.2)}
.b-green{background:rgba(5,150,105,.1);color:#4ade80;border:1px solid rgba(5,150,105,.2)}
.b-purple{background:rgba(124,58,237,.1);color:#a78bfa;border:1px solid rgba(124,58,237,.2)}
.b-gray{background:rgba(107,114,128,.1);color:var(--text-muted);border:1px solid var(--border)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border:none;font-family:inherit}
.btn-primary{background:var(--accent);color:#fff}.btn-primary:hover{background:#047857}
.btn-primary:disabled{background:rgba(5,150,105,.5);cursor:not-allowed}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text-secondary)}.btn-outline:hover{border-color:var(--border-light);color:var(--text)}
.btn-danger{background:rgba(220,38,38,.1);border:1px solid rgba(220,38,38,.2);color:#f87171}.btn-danger:hover{background:rgba(220,38,38,.15)}

/* TABS */
.tab-bar{display:flex;align-items:flex-end;gap:0;padding:0 20px;border-bottom:1px solid var(--border);flex-shrink:0;background:var(--surface)}
.tab{padding:12px 18px;font-size:13px;font-weight:500;color:var(--text-muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s}
.tab:hover{color:var(--text)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.tab-spacer{flex:1}

/* MISC */
.scrollable{overflow-y:auto}
.truncate{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.mono{font-family:'Public Sans',sans-serif;font-weight:700}

/* STAT ROW */
.stat-row{display:flex;gap:12px;padding:16px 20px;border-bottom:1px solid var(--border);flex-shrink:0;background:var(--surface)}
.stat-box{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 18px;flex:1;text-align:center;transition:.2s}
.stat-box:hover{border-color:var(--border-light)}
.stat-num{font-family:'Public Sans',sans-serif;font-weight:700;font-size:22px;font-weight:600;line-height:1;color:#fff}
.stat-lbl{font-size:10px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-top:5px}

/* SELECT/INPUT */
select,input,textarea{background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:var(--radius);padding:8px 12px;font-size:13px;font-family:inherit;outline:none;transition:border .15s}
select:focus,input:focus,textarea:focus{border-color:var(--accent)}
textarea{resize:vertical}

/* CHART */
.chart-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;display:flex;flex-direction:column}
.chart-title{font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:16px}
.chart-legend{display:flex;gap:18px;margin-top:14px;font-size:12px}
.chart-legend-item{display:flex;align-items:center;gap:6px;color:var(--text-muted)}

/* MAP */
.mapboxgl-map{font-family:'Public Sans',system-ui,-apple-system,sans-serif !important}
.mapboxgl-ctrl-bottom-left,.mapboxgl-ctrl-bottom-right{display:none !important}
.map-container{width:100%;height:100%;border-radius:var(--radius);overflow:hidden;position:relative}
.map-container.fullscreen{border-radius:0}
.mapboxgl-popup-content{background:transparent !important;box-shadow:none !important;padding:0 !important}
.mapboxgl-popup-tip{display:none !important}

/* ROUTE PANEL */
.route-panel{position:absolute;bottom:16px;left:16px;right:16px;background:rgba(17,18,23,.92);-webkit-backdrop-filter:blur(16px);backdrop-filter:blur(16px);border:1px solid var(--border);border-radius:12px;padding:14px 18px;z-index:15;display:flex;gap:16px;align-items:flex-start;animation:fadeSlideUp .4s ease-out;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.route-panel-close{position:absolute;top:12px;right:12px;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:18px;padding:4px;line-height:1}
.route-panel-close:hover{color:var(--text)}
.route-info{flex:1;min-width:0}
.route-info h3{font-size:14px;font-weight:600;color:#fff;margin-bottom:6px}
.route-info p{font-size:12px;color:var(--text-secondary);margin-bottom:3px}
.route-stats{display:flex;gap:16px;margin-top:12px}
.route-stat{background:var(--card-hover);border:1px solid var(--border);border-radius:8px;padding:8px 12px;text-align:center}
.route-stat .val{font-family:'Public Sans',sans-serif;font-weight:700;font-size:16px;font-weight:600;color:#fff}
.route-stat .lbl{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;margin-top:3px}
.route-actions{display:flex;flex-direction:column;gap:8px;flex-shrink:0}
.route-dispatch{display:flex;align-items:center;gap:8px;padding:10px 16px;border-radius:8px;border:1px solid var(--border);background:var(--card-hover);color:var(--text);cursor:pointer;font-size:13px;font-weight:500;font-family:inherit;transition:all .15s;white-space:nowrap}
.route-dispatch:hover{border-color:var(--border-light);background:var(--border)}
.route-dispatch.primary{background:var(--accent);border-color:var(--accent);color:#fff}
.route-dispatch.primary:hover{background:rgba(5,150,105,.85)}
.route-dispatch .emoji{font-size:16px}

/* (pulse handled by native Mapbox layers) */

/* ─── ANIMATIONS ────────────────────────────────────────────────── */
@keyframes fadeSlideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scaleIn{from{opacity:0;transform:scale(0.95)}to{opacity:1;transform:scale(1)}}
@keyframes growBar{from{transform:scaleY(0)}to{transform:scaleY(1)}}
@keyframes drawLine{from{stroke-dashoffset:var(--dash-len)}to{stroke-dashoffset:0}}
@keyframes fillDonut{from{stroke-dashoffset:var(--circ)}to{stroke-dashoffset:var(--offset)}}
@keyframes countPulse{0%{transform:scale(1)}50%{transform:scale(1.04)}100%{transform:scale(1)}}
.anim-card{animation:fadeSlideUp .5s ease-out both}
.anim-card:nth-child(1){animation-delay:.05s}
.anim-card:nth-child(2){animation-delay:.1s}
.anim-card:nth-child(3){animation-delay:.15s}
.anim-card:nth-child(4){animation-delay:.2s}
.anim-card:nth-child(5){animation-delay:.25s}
.anim-card:nth-child(6){animation-delay:.3s}
.anim-fade{animation:fadeIn .6s ease-out both}
.anim-scale{animation:scaleIn .4s ease-out both}
.anim-bar{transform-origin:bottom;animation:growBar .8s cubic-bezier(.22,1,.36,1) both}
.anim-line{animation:drawLine 1.2s ease-out both}
.anim-dot{animation:scaleIn .3s ease-out both}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);z-index:100;display:flex;align-items:center;justify-content:center;animation:fadeIn .15s ease-out}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:16px;width:94%;max-width:640px;max-height:88vh;display:flex;flex-direction:column;overflow:hidden;animation:scaleIn .25s ease-out;box-shadow:0 24px 64px rgba(0,0,0,.5)}

/* CHAT BUBBLES */
.chat-bubble{border-radius:18px;padding:14px 16px;border:1px solid var(--border)}
.chat-bubble.client{background:#111827;border-color:rgba(75,85,99,.55);border-bottom-left-radius:6px}
.chat-bubble.agent{background:linear-gradient(135deg,rgba(5,150,105,.22),rgba(6,95,70,.3));border-color:rgba(52,211,153,.3);border-bottom-right-radius:6px}

/* FEEDBACK CARD */
.fb-card{background:var(--card);padding:20px;border-radius:var(--radius);border:1px solid var(--border);cursor:pointer;transition:.2s}
.fb-card:hover{border-color:var(--accent);box-shadow:0 4px 24px rgba(5,150,105,.12);transform:translateY(-1px)}

/* SOS BANNER */
.sos-banner{box-shadow:0 2px 20px rgba(220,38,38,.25);animation:pulse 2s infinite}

/* STAT BOX HOVER */
.stat-box:hover{border-color:rgba(5,150,105,.3)}

/* SELECT STYLING */
select{-webkit-appearance:none;appearance:none}

/* TABLE ROW */
tr{transition:.1s}
tr:hover td{background:var(--card-hover)}


/* ── RELATÓRIOS — GOVERNO INSTITUCIONAL ──────────────────── */
.rel-header{padding:20px 28px;border-bottom:1px solid var(--border);flex-shrink:0;background:var(--surface);display:flex;align-items:center;justify-content:space-between}
.rel-title{font-family:'Public Sans',sans-serif;font-size:22px;font-weight:700;color:#fff;letter-spacing:-.3px}
.rel-subtitle{font-size:12px;color:var(--text-muted);margin-top:3px;font-weight:500;letter-spacing:.2px}
.rel-period-btn{padding:6px 16px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Public Sans',sans-serif;transition:all .15s;border:1px solid var(--border);background:transparent;color:var(--text-muted)}
.rel-period-btn:hover{border-color:var(--border-light);color:var(--text)}
.rel-period-btn.active{background:#1e3a5f;border-color:#1e3a5f;color:#fff}
.rel-hero{padding:28px 32px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:24px}
.rel-hero-label{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:12px}
.rel-hero-value{font-family:'Public Sans',sans-serif;font-size:46px;font-weight:900;color:#fff;letter-spacing:-1.5px;line-height:1}
.rel-hero-trend{font-size:13px;font-weight:600;color:#059669;margin-left:16px;display:inline-flex;align-items:center;gap:4px}
.rel-section-title{font-family:'Public Sans',sans-serif;font-size:15px;font-weight:700;color:#fff;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between}
.rel-section-badge{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;padding:5px 12px;border:1px solid var(--border);border-radius:6px;background:var(--card)}
.rel-kpi{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px 20px;position:relative;overflow:hidden;transition:border-color .2s}
.rel-kpi:hover{border-color:var(--border-light)}
.rel-kpi-bar{position:absolute;top:0;left:0;right:0;height:3px;opacity:.7}
.rel-kpi-value{font-family:'Public Sans',sans-serif;font-size:30px;font-weight:800;line-height:1}
.rel-kpi-label{font-size:11px;font-weight:600;color:var(--text-muted);margin-top:8px;text-transform:uppercase;letter-spacing:.6px}
.rel-kpi-sub{font-size:11px;color:var(--text-muted);margin-top:5px;opacity:.7}
.rel-table{width:100%;border-collapse:separate;border-spacing:0}
.rel-table th{text-align:left;padding:10px 16px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);border-bottom:1px solid var(--border);background:transparent}
.rel-table td{padding:14px 16px;border-bottom:1px solid rgba(35,37,46,.6);font-size:13px;color:var(--text-secondary);vertical-align:middle}
.rel-table tr:hover td{background:rgba(255,255,255,.015)}
.rel-table tr:last-child td{border-bottom:none}
.rel-pill{display:inline-flex;align-items:center;gap:7px;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600}
.rel-pill-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.rel-progress-track{height:6px;border-radius:3px;background:rgba(255,255,255,.06);overflow:hidden;min-width:100px}
.rel-progress-fill{height:100%;border-radius:3px;transition:width .8s cubic-bezier(.22,1,.36,1)}
.rel-sentiment{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600}
.rel-sentiment-dot{width:6px;height:6px;border-radius:50%}
.rel-trend-arrow{font-size:16px;font-weight:700;line-height:1}
.rel-donut-legend{display:flex;flex-direction:column;gap:10px}
.rel-donut-item{display:flex;align-items:center;justify-content:space-between}
.rel-donut-item-left{display:flex;align-items:center;gap:8px}
.rel-donut-item-dot{width:8px;height:8px;border-radius:50%}
.rel-donut-item-label{font-size:12px;color:var(--text-muted);font-weight:500}
.rel-donut-item-value{font-family:'Public Sans',sans-serif;font-size:13px;font-weight:700}
.rel-mini-card{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:10px;padding:16px 14px;text-align:center}
.rel-mini-card-value{font-family:'Public Sans',sans-serif;font-size:16px;font-weight:800}
.rel-mini-card-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;margin-top:6px;font-weight:600}
@keyframes relFadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.rel-animate{animation:relFadeUp .5s ease-out both}
.rel-animate:nth-child(1){animation-delay:.03s}.rel-animate:nth-child(2){animation-delay:.06s}.rel-animate:nth-child(3){animation-delay:.09s}.rel-animate:nth-child(4){animation-delay:.12s}.rel-animate:nth-child(5){animation-delay:.15s}.rel-animate:nth-child(6){animation-delay:.18s}.rel-animate:nth-child(7){animation-delay:.21s}.rel-animate:nth-child(8){animation-delay:.24s}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel" data-presets="react">
const {useState,useEffect,useRef,useCallback,useMemo}=React;
const MAPBOX_TOKEN='pk.eyJ1Ijoibm9kZWRhdGEiLCJhIjoiY21tejgxMm1hMDVxajJ3cTU2Z3ZrNTBiZSJ9.t6vT60mOCmGpYrHfRSykrw';

/* ─── ANIMATED NUMBER (counts from 0 to target) ────────────── */
function AnimatedNumber({value,duration=1200,prefix='',suffix='',style={},className=''}){
  const [display,setDisplay]=useState(0);
  const numVal=typeof value==='string'?parseFloat(value.replace(/[^\d.-]/g,''))||0:value;
  const isNum=!isNaN(numVal)&&isFinite(numVal);
  useEffect(()=>{
    if(!isNum){setDisplay(value);return;}
    let start=null;const from=0;const to=numVal;
    function step(ts){
      if(!start)start=ts;
      const p=Math.min((ts-start)/duration,1);
      const ease=1-Math.pow(1-p,3);
      setDisplay(Math.round(from+(to-from)*ease));
      if(p<1)requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  },[numVal]);
  if(!isNum)return <span className={className} style={style}>{prefix}{value}{suffix}</span>;
  return <span className={className} style={style}>{prefix}{display.toLocaleString('pt-BR')}{suffix}</span>;
}

/* ─── ANIMATED MONEY (conta centavos de 0 ao valor) ────────── */
function AnimMoney({value,style:s={}}){
  const cents=Math.round((value||0)*100);
  const [disp,setDisp]=useState(0);
  useEffect(()=>{
    let start=null;
    function step(ts){if(!start)start=ts;const p=Math.min((ts-start)/1500,1);const ease=1-Math.pow(1-p,3);setDisp(Math.round(ease*cents));if(p<1)requestAnimationFrame(step);}
    requestAnimationFrame(step);
  },[cents]);
  return <span style={s}>R$ {(disp/100).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2})}</span>;
}

/* ─── PILL BADGE (dot colorido, sem emoji) ─────────────────── */
function Pill({label,color}){
  return(
    <span className="rel-pill" style={{background:`${color}12`,color:color}}>
      <span className="rel-pill-dot" style={{background:color}}/>
      {label}
    </span>
  );
}

/* ─── PAGE TRANSITION WRAPPER ──────────────────────────────── */
function PageTransition({children,pageKey}){
  const [show,setShow]=useState(false);
  useEffect(()=>{setShow(false);requestAnimationFrame(()=>setShow(true));},[pageKey]);
  return <div style={{opacity:show?1:0,transform:show?'translateY(0)':'translateY(8px)',transition:'opacity .35s ease, transform .35s ease',height:'100%'}}>{children}</div>;
}

