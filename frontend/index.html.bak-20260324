/* ─── MAPBOX (100% NATIVE LAYERS — circle + pulse) ───────────── */
function MapboxMap({items=[],fullscreen=false,style={},showBases=false,route=null,heatmapData=null,heatmapMode=false}){
  const mapRef=useRef(null);
  const containerRef=useRef(null);
  const popupRef=useRef(null);
  const readyRef=useRef(false);
  const pulseRef=useRef(null);
  const [basesVisible,setBasesVisible]=useState(showBases);

  const sevStops=['critica','#dc2626','alta','#ef4444','media','#d97706','baixa','#059669'];

  function basesToGeoJSON(){
    return{type:'FeatureCollection',features:BASES.map(b=>({
      type:'Feature',geometry:{type:'Point',coordinates:[b.lng,b.lat]},
      properties:{id:b.id,nome:b.nome,endereco:b.endereco,telefone:b.telefone,tipo:b.tipo}
    }))};
  }

  function itemsToGeoJSON(list){
    return{type:'FeatureCollection',features:list.filter(i=>i.lat&&i.lng).map((item,idx)=>{
      const sev=SEV[item.severidade]||SEV.baixa;
      return{type:'Feature',geometry:{type:'Point',coordinates:[item.lng,item.lat]},properties:{
        id:item.id||idx,titulo:item.titulo||item.mensagem||'Alerta SOS',bairro:item.bairro||'—',
        sevLabel:sev.label,sevColor:sev.c,dotColor:sev.dot,
        severidade:item.severidade||'baixa',
        tipo:item.tipo||item.categoria||'ocorrencia',
        protocolo:item.protocolo||'',
        total_relatos:item.total_relatos||1,
        endereco:item.endereco||'',
      }};
    })};
  }

  useEffect(()=>{
    if(!containerRef.current||mapRef.current) return;
    mapboxgl.accessToken=MAPBOX_TOKEN;
    const map=new mapboxgl.Map({
      container:containerRef.current,
      style:'mapbox://styles/mapbox/dark-v11',
      center:[-51.9375,-23.4205],
      zoom:13,pitch:45,bearing:-10,antialias:true,
    });
    map.addControl(new mapboxgl.NavigationControl({showCompass:true,visualizePitch:true}),'top-right');
    popupRef.current=new mapboxgl.Popup({closeButton:false,closeOnClick:true,maxWidth:'280px',offset:14});

    map.on('load',()=>{
      // Terrain + 3D
      map.addSource('mapbox-dem',{type:'raster-dem',url:'mapbox://mapbox.mapbox-terrain-dem-v1',tileSize:512});
      map.setTerrain({source:'mapbox-dem',exaggeration:1.5});
      map.addLayer({id:'3d-buildings',source:'composite','source-layer':'building',filter:['==','extrude','true'],type:'fill-extrusion',minzoom:13,paint:{'fill-extrusion-color':'#0f1520','fill-extrusion-height':['get','height'],'fill-extrusion-base':['get','min_height'],'fill-extrusion-opacity':.5}});

      // ── Route ──
      map.addSource('route',{type:'geojson',data:{type:'Feature',geometry:{type:'LineString',coordinates:[]}}});
      map.addLayer({id:'route-line-shadow',type:'line',source:'route',layout:{'line-join':'round','line-cap':'round'},paint:{'line-color':'#000','line-width':8,'line-opacity':0.3,'line-blur':4}});
      map.addLayer({id:'route-line',type:'line',source:'route',layout:{'line-join':'round','line-cap':'round'},paint:{'line-color':'#3b82f6','line-width':4,'line-opacity':0.9}});
      map.addLayer({id:'route-line-glow',type:'line',source:'route',layout:{'line-join':'round','line-cap':'round'},paint:{'line-color':'#3b82f6','line-width':10,'line-opacity':0.15,'line-blur':6}});

      // ── Incidents source ──
      map.addSource('incidents',{type:'geojson',data:{type:'FeatureCollection',features:[]}});

      // Aura externa (só critica/alta — "zona de perigo")
      map.addLayer({id:'inc-glow',type:'circle',source:'incidents',
        filter:['in',['get','severidade'],['literal',['critica','alta']]],
        paint:{
          'circle-radius':['match',['get','severidade'],'critica',28,'alta',22,18],
          'circle-color':['match',['get','severidade'],...sevStops,'#8b949e'],
          'circle-opacity':0.12,
          'circle-blur':1.2,
      }});

      // Pulse halo — animado via JS
      map.addLayer({id:'inc-pulse1',type:'circle',source:'incidents',paint:{
        'circle-radius':['match',['get','severidade'],'critica',20,'alta',16,'media',12,'baixa',9,10],
        'circle-color':['match',['get','severidade'],...sevStops,'#8b949e'],
        'circle-opacity':0.45,
        'circle-blur':0.6,
      }});

      // Círculo principal sólido
      map.addLayer({id:'inc-main',type:'circle',source:'incidents',paint:{
        'circle-radius':['match',['get','severidade'],'critica',9,'alta',7.5,'media',6,'baixa',4.5,5],
        'circle-color':['match',['get','severidade'],...sevStops,'#8b949e'],
        'circle-opacity':0.95,
        'circle-stroke-width':1.5,
        'circle-stroke-color':'rgba(255,255,255,0.7)',
        'circle-stroke-opacity':1,
      }});

      // ── Bases: Circle layers nativos (fixos no zoom/pitch) ──
      var baseCores=['gcm','#3b82f6','samu','#ef4444','bombeiros','#f97316','pm','#a855f7'];
      map.addSource('bases',{type:'geojson',data:showBases?basesToGeoJSON():{type:'FeatureCollection',features:[]}});
      // Halo sutil
      map.addLayer({id:'base-halo',type:'circle',source:'bases',paint:{
        'circle-radius':10,
        'circle-color':['match',['get','tipo'],...baseCores,'#6b7280'],
        'circle-opacity':0.15,
        'circle-blur':0.8,
      }});
      // Ponto principal
      map.addLayer({id:'base-dot',type:'circle',source:'bases',paint:{
        'circle-radius':6,
        'circle-color':['match',['get','tipo'],...baseCores,'#6b7280'],
        'circle-opacity':1,
        'circle-stroke-width':2.5,
        'circle-stroke-color':'#ffffff',
        'circle-stroke-opacity':0.9,
      }});
      // Ponto central branco
      map.addLayer({id:'base-center',type:'circle',source:'bases',paint:{
        'circle-radius':2,
        'circle-color':'#ffffff',
        'circle-opacity':0.85,
      }});
      // Popup das bases
      map.on('click','base-dot',(e)=>{
        const f=e.features[0];const coords=f.geometry.coordinates.slice();const p=f.properties;
        var tipoCores={gcm:'#3b82f6',samu:'#ef4444',bombeiros:'#f97316',pm:'#a855f7'};
        var cor=tipoCores[p.tipo]||'#6b7280';
        popupRef.current.setLngLat(coords).setHTML(
          '<div style="background:#111217;border:1px solid #23252e;border-radius:10px;padding:12px 14px;color:#fff;font-family:Public Sans,system-ui;min-width:170px;box-shadow:0 8px 24px rgba(0,0,0,.5)">'+
          '<div style="font-weight:700;font-size:14px;margin-bottom:3px">'+p.nome+'</div>'+
          '<div style="font-size:11px;color:#9ca3af;line-height:1.4">'+p.endereco+'</div>'+
          '<div style="font-size:13px;color:'+cor+';margin-top:8px;font-weight:600">'+p.telefone+'</div></div>'
        ).addTo(map);
      });
      map.on('mouseenter','base-dot',()=>{map.getCanvas().style.cursor='pointer';});
      map.on('mouseleave','base-dot',()=>{map.getCanvas().style.cursor='';});

      // ── Heatmap source + layers ──
      map.addSource('heatmap-data',{type:'geojson',data:{type:'FeatureCollection',features:[]}});
      map.addLayer({id:'heatmap-layer',type:'heatmap',source:'heatmap-data',maxzoom:16,paint:{
        'heatmap-weight':['interpolate',['linear'],['get','weight'],0,0,1,1],
        'heatmap-intensity':['interpolate',['linear'],['zoom'],10,1,16,3],
        'heatmap-color':['interpolate',['linear'],['heatmap-density'],
          0,'rgba(0,0,0,0)',
          0.1,'rgba(5,150,105,0.2)',
          0.3,'rgba(59,130,246,0.4)',
          0.5,'rgba(217,119,6,0.6)',
          0.7,'rgba(239,68,68,0.7)',
          1,'rgba(220,38,38,0.9)',
        ],
        'heatmap-radius':['interpolate',['linear'],['zoom'],10,20,16,40],
        'heatmap-opacity':0,
      }},fullscreen?'inc-glow':undefined);

      // ══════ Animação Pulse (3 layers, ciclo 3s) ══════
      let pulsePhase=0;
      function animatePulse(){
        pulsePhase=(pulsePhase+1)%180;
        const t=pulsePhase/180;
        const sin1=Math.sin(t*Math.PI*2);
        const sin2=Math.sin(t*Math.PI*2+0.8);
        // inc-pulse1: halo interno
        const ps=1+0.35*sin1;
        const po=0.35+0.20*sin1;
        try{
          map.setPaintProperty('inc-pulse1','circle-radius',[
            'match',['get','severidade'],
            'critica',20*ps,'alta',16*ps,'media',12*ps,'baixa',9*ps,10*ps
          ]);
          map.setPaintProperty('inc-pulse1','circle-opacity',po);
        }catch(e){}
        // inc-glow: aura externa (critica/alta)
        const gs=1+0.25*sin2;
        const go=0.08+0.10*sin2;
        try{
          map.setPaintProperty('inc-glow','circle-radius',[
            'match',['get','severidade'],'critica',28*gs,'alta',22*gs,18*gs
          ]);
          map.setPaintProperty('inc-glow','circle-opacity',go);
        }catch(e){}
        map.triggerRepaint();
        pulseRef.current=requestAnimationFrame(animatePulse);
      }
      animatePulse();

      // ── Popups ──
      map.on('click','inc-main',(e)=>{
        const f=e.features[0];const coords=f.geometry.coordinates.slice();const p=f.properties;
        const sevCores={critica:'#ef4444',alta:'#f97316',media:'#eab308',baixa:'#22c55e'};
        const sevCor=sevCores[p.severidade]||'#6b7280';
        const sevLabel=(p.severidade||'baixa').charAt(0).toUpperCase()+(p.severidade||'baixa').slice(1);
        popupRef.current.setLngLat(coords).setHTML(
          `<div style="background:#111217;border:1px solid #23252e;border-radius:10px;padding:12px 14px;color:#fff;font-family:Public Sans,system-ui;min-width:200px;box-shadow:0 8px 24px rgba(0,0,0,.5)">
            <div style="font-weight:600;font-size:14px;margin-bottom:4px;line-height:1.3">${p.titulo}</div>
            <div style="font-size:12px;color:#9ca3af;margin-bottom:6px">${p.protocolo||''}</div>
            <div style="display:flex;gap:6px;margin-bottom:6px">
              <span style="background:${sevCor};color:#fff;padding:2px 8px;border-radius:10px;font-size:11px">${sevLabel}</span>
              <span style="background:#374151;color:#d1d5db;padding:2px 8px;border-radius:10px;font-size:11px">\u{1F465} ${p.total_relatos||1}</span>
            </div>
            <div style="font-size:12px;color:#d1d5db">${p.endereco||p.bairro||''}</div>
          </div>`
        ).addTo(map);
      });
      // Cursor pointer nas ocorrências
      map.on('mouseenter','inc-main',()=>{map.getCanvas().style.cursor='pointer';});
      map.on('mouseleave','inc-main',()=>{map.getCanvas().style.cursor='';});

      readyRef.current=true;
    });
    mapRef.current=map;
    return()=>{
      if(pulseRef.current) cancelAnimationFrame(pulseRef.current);
      map.remove();mapRef.current=null;readyRef.current=false;
    };
  },[]);

  // Update route
  useEffect(()=>{
    const map=mapRef.current;if(!map) return;
    const apply=()=>{
      const src=map.getSource('route');if(!src) return;
      if(route&&route.geometry){
        src.setData({type:'Feature',geometry:route.geometry});
        const coords=route.geometry.coordinates;
        if(coords.length>1){
          const bounds=coords.reduce((b,c)=>b.extend(c),new mapboxgl.LngLatBounds(coords[0],coords[0]));
          map.fitBounds(bounds,{padding:{top:80,bottom:200,left:80,right:80},duration:1200});
        }
      }else{src.setData({type:'Feature',geometry:{type:'LineString',coordinates:[]}});}
    };
    if(readyRef.current){apply();}else{map.once('load',apply);}
  },[route]);

  // Update incident points
  useEffect(()=>{
    const map=mapRef.current;if(!map) return;
    const apply=()=>{const src=map.getSource('incidents');if(src) src.setData(itemsToGeoJSON(items));};
    if(readyRef.current){apply();}else{map.once('load',apply);}
  },[items]);

  // Toggle base layers visibility
  useEffect(()=>{
    const map=mapRef.current;if(!map) return;
    const apply=()=>{
      try{
        const src=map.getSource('bases');if(!src) return;
        src.setData(basesVisible?basesToGeoJSON():{type:'FeatureCollection',features:[]});
      }catch(e){}
    };
    if(readyRef.current){apply();}else{map.once('load',apply);}
  },[basesVisible]);

  // Update heatmap data
  useEffect(()=>{
    const map=mapRef.current;if(!map) return;
    const apply=()=>{
      const src=map.getSource('heatmap-data');if(!src) return;
      if(heatmapData&&heatmapData.length>0){
        src.setData({type:'FeatureCollection',features:heatmapData.filter(i=>i.lat&&i.lng).map((item,idx)=>({
          type:'Feature',geometry:{type:'Point',coordinates:[item.lng,item.lat]},
          properties:{weight:item.weight||1},
        }))});
      }else{src.setData({type:'FeatureCollection',features:[]});}
    };
    if(readyRef.current){apply();}else{map.once('load',apply);}
  },[heatmapData]);

  // Toggle heatmap vs markers visibility
  useEffect(()=>{
    const map=mapRef.current;if(!map) return;
    const apply=()=>{
      try{
        const heatOpacity=heatmapMode?0.85:0;
        map.setPaintProperty('heatmap-layer','heatmap-opacity',heatOpacity);
        ['inc-glow','inc-pulse1','inc-main'].forEach(l=>{
          try{map.setLayoutProperty(l,'visibility',heatmapMode?'none':'visible');}catch(e){}
        });
      }catch(e){}
    };
    if(readyRef.current){apply();}else{map.once('load',apply);}
  },[heatmapMode]);

  // Resize
  useEffect(()=>{if(mapRef.current) setTimeout(()=>mapRef.current.resize(),150);});

  return(
    <div style={{position:'relative',width:'100%',height:'100%'}}>
      <div ref={containerRef} className={`map-container${fullscreen?' fullscreen':''}`} style={style}/>
      {showBases&&(
        <button onClick={()=>setBasesVisible(v=>!v)} style={{
          position:'absolute',bottom:16,left:16,zIndex:5,
          background:basesVisible?'var(--accent)':'rgba(18,18,18,0.9)',
          border:'1px solid '+(basesVisible?'var(--accent)':'var(--border)'),
          color:basesVisible?'#fff':'var(--text-muted)',
          fontSize:12,padding:'6px 12px',borderRadius:6,cursor:'pointer',
          backdropFilter:'blur(12px)',transition:'all .2s',
        }}>
          {basesVisible?'\u{1F441}\uFE0F Bases vis\u00edveis':'\u{1F441}\uFE0F Mostrar bases'}
        </button>
      )}
    </div>
  );
}

/* ─── ROUTE PANEL ─────────────────────────────────────────────── */
function RoutePanel({route,base,incident,onClose}){
  if(!route||!base||!incident) return null;
  const durMin=Math.ceil(route.duration/60);
  const distKm=(route.distance/1000).toFixed(1);
  const gmapLink=googleMapsLink(base.lat,base.lng,incident.lat,incident.lng);
  const wazeLink=`https://waze.com/ul?ll=${incident.lat},${incident.lng}&navigate=yes`;
  const msgText=encodeURIComponent(`🚨 DESPACHO URGENTE\n📍 ${incident.titulo||incident.mensagem||'Alerta SOS'}\n🏘️ ${incident.bairro||'—'}\n⏱️ ETA: ${durMin}min (${distKm}km)\n🗺️ Rota: ${gmapLink}`);
  return(
    <div className="route-panel">
      <button className="route-panel-close" onClick={onClose}>✕</button>
      <div className="route-info">
        <h3>{base.icon} {base.nome} → {incident.titulo||incident.mensagem||'Alerta'}</h3>
        <p>{base.endereco} → {incident.bairro||'—'}</p>
        <div className="route-stats">
          <div className="route-stat"><div className="val" style={{color:'#3b82f6'}}>{durMin}<span style={{fontSize:12,fontWeight:400}}>min</span></div><div className="lbl">Tempo Est.</div></div>
          <div className="route-stat"><div className="val">{distKm}<span style={{fontSize:12,fontWeight:400}}>km</span></div><div className="lbl">Distância</div></div>
          <div className="route-stat"><div className="val" style={{color:SEV[incident.severidade]?.c||'#fbbf24'}}>{SEV[incident.severidade]?.label||'—'}</div><div className="lbl">Severidade</div></div>
        </div>
      </div>
      <div className="route-actions">
        <a href={gmapLink} target="_blank" rel="noopener" className="route-dispatch primary" style={{textDecoration:'none'}}><span className="emoji">🗺️</span> Abrir Google Maps</a>
        <a href={wazeLink} target="_blank" rel="noopener" className="route-dispatch" style={{textDecoration:'none'}}><span className="emoji">🧭</span> Abrir Waze</a>
        <a href={`https://wa.me/?text=${msgText}`} target="_blank" rel="noopener" className="route-dispatch" style={{textDecoration:'none'}}><span className="emoji">📲</span> Enviar WhatsApp</a>
        <button className="route-dispatch" onClick={()=>{navigator.clipboard.writeText(decodeURIComponent(msgText));}}><span className="emoji">📋</span> Copiar Despacho</button>
      </div>
    </div>
  );
}

/* ─── CHARTS (ANIMATED) ────────────────────────────────────── */
function BarChart({data,keys,colors,height=220}){
  const max=Math.max(...data.flatMap(d=>keys.map(k=>d[k]||0)))*1.1||1;
  const W=500,H=height,PAD={l:50,r:15,t:10,b:36};
  const cW=W-PAD.l-PAD.r,cH=H-PAD.t-PAD.b;
  const gw=cW/data.length;
  const bw=Math.min(24,gw*0.28);
  const total=keys.length*(bw+3)-3;
  return(
    <svg viewBox={`0 0 ${W} ${H}`} style={{width:'100%',height:'auto'}}>
      {[0,.25,.5,.75,1].map(p=>{
        const y=PAD.t+cH*(1-p);
        return(<g key={p}><line x1={PAD.l} y1={y} x2={W-PAD.r} y2={y} stroke="#23252e" strokeWidth="1"/><text x={PAD.l-8} y={y+4} textAnchor="end" fontSize="10" fill="#8b949e" fontFamily="Public Sans">{Math.round(max*p)}</text></g>);
      })}
      {data.map((d,di)=>{
        const cx=PAD.l+di*gw+gw/2;
        return(<g key={di}>
          {keys.map((k,ki)=>{
            const val=d[k]||0;const bh=max>0?(cH*(val/max)):0;
            const x=cx-total/2+ki*(bw+3);const y=PAD.t+cH-bh;
            const delay=di*0.08+ki*0.04;
            return(<g key={k}>
              <rect x={x} y={y} width={bw} height={bh} fill={colors[ki]} rx="3" opacity=".85"
                className="anim-bar" style={{animationDelay:`${delay}s`}}/>
              {val>0&&<text x={x+bw/2} y={y-4} textAnchor="middle" fontSize="10" fill="#d1d5db" fontFamily="Public Sans"
                className="anim-fade" style={{animationDelay:`${delay+0.4}s`}}>{val}</text>}
            </g>);
          })}
          <text x={cx} y={H-PAD.b+18} textAnchor="middle" fontSize="11" fill="#8b949e" fontFamily="Public Sans">{d.label}</text>
        </g>);
      })}
    </svg>
  );
}

function AreaChart({data,keys,colors,height=220}){
  const max=Math.max(...data.flatMap(d=>keys.map(k=>d[k]||0)))*1.15||1;
  const W=500,H=height,PAD={l:50,r:15,t:10,b:36};
  const cW=W-PAD.l-PAD.r,cH=H-PAD.t-PAD.b;
  const pts=(k)=>data.map((d,i)=>[PAD.l+i*cW/(data.length-1),PAD.t+cH*(1-(d[k]||0)/max)]);
  const toP=(pts)=>pts.map((p,i)=>`${i===0?'M':'L'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
  const toA=(arr)=>{const l=arr[arr.length-1],f=arr[0];return toP(arr)+` L${l[0].toFixed(1)},${PAD.t+cH} L${f[0].toFixed(1)},${PAD.t+cH} Z`;};
  const lineRef=useRef([]);
  const [ready,setReady]=useState(false);
  useEffect(()=>{setTimeout(()=>setReady(true),50);},[]);
  return(
    <svg viewBox={`0 0 ${W} ${H}`} style={{width:'100%',height:'auto'}}>
      <defs>{keys.map((k,ki)=><linearGradient key={k} id={`ag${ki}`} x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stopColor={colors[ki]} stopOpacity=".2"/><stop offset="100%" stopColor={colors[ki]} stopOpacity=".01"/></linearGradient>)}</defs>
      {[0,.25,.5,.75,1].map(p=>{
        const y=PAD.t+cH*(1-p);
        return(<g key={p}><line x1={PAD.l} y1={y} x2={W-PAD.r} y2={y} stroke="#23252e" strokeWidth="1"/><text x={PAD.l-8} y={y+4} textAnchor="end" fontSize="10" fill="#8b949e" fontFamily="Public Sans">{Math.round(max*p)}</text></g>);
      })}
      {keys.map((k,ki)=>{
        const p=pts(k);
        const pathD=toP(p);
        return(<g key={k}>
          <path d={toA(p)} fill={`url(#ag${ki})`} className="anim-fade" style={{animationDelay:`${ki*0.2+0.6}s`}}/>
          <path ref={el=>{if(el&&!lineRef.current[ki]){const len=el.getTotalLength();el.style.strokeDasharray=len;el.style.strokeDashoffset=len;el.style.setProperty('--dash-len',len);lineRef.current[ki]=true;}}}
            d={pathD} fill="none" stroke={colors[ki]} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"
            className={ready?'anim-line':''} style={{animationDelay:`${ki*0.2}s`}}/>
          {p.map((pt,i)=><circle key={i} cx={pt[0]} cy={pt[1]} r="4" fill="#0b0c10" stroke={colors[ki]} strokeWidth="2.5"
            className="anim-dot" style={{animationDelay:`${0.15*i+ki*0.2+0.3}s`}}/>)}
        </g>);
      })}
      {data.map((d,i)=>{const x=PAD.l+i*cW/(data.length-1);return <text key={i} x={x} y={H-PAD.b+18} textAnchor="middle" fontSize="11" fill="#8b949e" fontFamily="Public Sans">{d.label}</text>;})}
    </svg>
  );
}

function DonutChart({data,size=160}){
  const total=data.reduce((a,d)=>a+d.v,0);
  const cx=50,cy=50,r=34,strokeW=10;
  const circ=2*Math.PI*r;
  let cumOffset=0;
  const segments=data.map((d,i)=>{
    const pct=d.v/total;
    const dashLen=circ*pct;
    const gap=circ-dashLen;
    const offset=cumOffset;
    cumOffset+=dashLen;
    return{...d,dashLen,gap,offset,delay:i*0.15};
  });
  return(<svg viewBox="0 0 100 100" style={{width:size,height:size,flexShrink:0}}>
    <circle cx={cx} cy={cy} r={r} fill="none" stroke="#23252e" strokeWidth={strokeW}/>
    {segments.map((s,i)=>(
      <circle key={i} cx={cx} cy={cy} r={r} fill="none" stroke={s.c} strokeWidth={strokeW}
        strokeDasharray={`${s.dashLen} ${s.gap}`}
        strokeDashoffset={-s.offset}
        strokeLinecap="round"
        transform={`rotate(-90 ${cx} ${cy})`}
        style={{opacity:0,animation:`fadeIn .6s ease-out ${s.delay+0.2}s both`}}/>
    ))}
    <AnimatedNumber value={total} prefix="" suffix="" duration={1000}
      className="" style={{}} />
    <text x="50" y="48" textAnchor="middle" fontSize="14" fill="#ffffff" fontFamily="Public Sans" fontWeight="600">{total}</text>
    <text x="50" y="58" textAnchor="middle" fontSize="6.5" fill="#8b949e" fontFamily="Public Sans" fontWeight="500">TOTAL</text>
  </svg>);
}

/* ─── CENTRAL ─────────────────────────────────────────────────── */
function Central({sos}){
  const [routeData,setRouteData]=useState(null);
  const [routeBase,setRouteBase]=useState(null);
  const [routeIncident,setRouteIncident]=useState(null);
  const [loadingRoute,setLoadingRoute]=useState(false);
  const [selFeed,setSelFeed]=useState(null);

  async function handleTraceRoute(item){
    setLoadingRoute(true);
    const isSOS=!!item.sos_cadastros;
    const base=nearestBase(item.lat,item.lng,isSOS?'pm':'gcm');
    if(!base){setLoadingRoute(false);return;}
    const r=await fetchRoute(base.lng,base.lat,item.lng,item.lat);
    if(r){setRouteData(r);setRouteBase(base);setRouteIncident(item);}
    setLoadingRoute(false);
  }

  const feed=[
    ...OC.slice(0,4).map(o=>({...o,tipo:'oc'})),
    ...DEN.slice(0,3).map(d=>({...d,tipo:'den'})),
    ...SOS.map(s=>({...s,tipo:'sos'})),
  ].sort((a,b)=>new Date(b.created_at)-new Date(a.created_at));
  return(
    <div style={{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden',position:'relative'}}>
      <div className="kpi-grid">
        {[
          {icon:'🚨',val:sos,lbl:'SOS Ativos',color:'#dc2626',bg:'rgba(220,38,38,.08)',border:sos?'rgba(220,38,38,.25)':''},
          {icon:'⚠',val:OC.filter(o=>o.status!=='resolvido').length,lbl:'Ocorrências Abertas',color:'#fbbf24',bg:'rgba(251,191,36,.08)'},
          {icon:'📋',val:DEN.length,lbl:'Denúncias Hoje',color:'#3b82f6',bg:'rgba(59,130,246,.08)'},
          {icon:'⏱',val:'18min',lbl:'Tempo Médio',color:'#059669',bg:'rgba(5,150,105,.08)'},
        ].map((k,i)=>(
          <div key={i} className="kpi anim-card" style={{borderColor:k.border||'var(--border)',borderLeft:`3px solid ${k.color}`}}>
            <div className="kpi-top">
              <span className="kpi-label">{k.lbl}</span>
              <div className="kpi-icon" style={{background:k.bg}}><span style={{fontSize:16}}>{k.icon}</span></div>
            </div>
            <div className="kpi-value" style={{color:k.color}}>
              {typeof k.val==='number'?<AnimatedNumber value={k.val} duration={1000}/>:k.val}
            </div>
          </div>
        ))}
      </div>
      <div style={{flex:1,display:'flex',gap:16,padding:'0 20px 20px',overflow:'hidden',minHeight:0}}>
        <div style={{flex:1,minWidth:0,borderRadius:'var(--radius)',overflow:'hidden',position:'relative'}}>
          <MapboxMap items={[...OC.filter(o=>o.status!=='resolvido'),...SOS.map(s=>({...s,severidade:'critica',titulo:'SOS: '+s.sos_cadastros?.nome}))]} showBases={true} route={routeData}/>
          {routeData&&<RoutePanel route={routeData} base={routeBase} incident={routeIncident} onClose={()=>{setRouteData(null);setRouteBase(null);setRouteIncident(null);}}/>}
        </div>
        <div style={{width:340,flexShrink:0,display:'flex',flexDirection:'column'}}>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:12}}>
            <div style={{width:6,height:6,borderRadius:'50%',background:'var(--success-light)',animation:'pulse 2s infinite'}}/>
            <span style={{fontSize:12,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'1px'}}>Alertas de Prioridade</span>
          </div>
          <div className="card scrollable" style={{flex:1,minHeight:0}}>
            {feed.map((item,i)=>{
              const isSOS=item.tipo==='sos';const isDen=item.tipo==='den';
              const cat=isDen?CAT_DEN[item.categoria]:CAT_OC[item.categoria];
              const borderColor=isSOS?'#dc2626':isDen?'#7c3aed':'#3b82f6';
              const statusMap=isSOS?{ativo:{label:'Ativo',badge:'b-red'},resolvido:{label:'Resolvido',badge:'b-green'}}:isDen?S_DEN:S_OC;
              const st=statusMap[item.status]||{label:item.status||'—',badge:'b-gray'};
              const horaExata=item.created_at?new Date(item.created_at).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}):'';
              const dataExata=item.created_at?new Date(item.created_at).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}):'';
              return(
                <div key={i} onClick={()=>setSelFeed(item)} style={{padding:'14px 16px',borderBottom:'1px solid var(--border)',borderLeft:`3px solid ${borderColor}`,cursor:'pointer',transition:'background .15s'}}
                  onMouseEnter={e=>e.currentTarget.style.background='rgba(255,255,255,.04)'}
                  onMouseLeave={e=>e.currentTarget.style.background='transparent'}>
                  <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:6}}>
                    <span style={{fontSize:11,fontWeight:600,color:isSOS?'#f87171':isDen?'#a78bfa':'#3b82f6',textTransform:'uppercase',letterSpacing:'.5px'}}>{isSOS?'SOS MULHER':(cat?.label||item.categoria)}</span>
                    <span style={{fontSize:10,color:'var(--text-muted)',fontFamily:'var(--font-mono)'}}>{dataExata} {horaExata}</span>
                  </div>
                  <div className="truncate" style={{fontSize:13.5,color:'var(--text)',fontWeight:500,marginBottom:4}}>{item.titulo||item.mensagem||item.sos_cadastros?.nome||'—'}</div>
                  <div style={{fontSize:12,color:'var(--text-muted)',marginBottom:8}}>{item.bairro||item.endereco||(item.latitude?'📍 GPS':'—')}</div>
                  <div style={{display:'flex',alignItems:'center',gap:6}}>
                    <span className={`badge ${st.badge}`} style={{fontSize:10,padding:'2px 8px'}}>{st.label}</span>
                    {(item.latitude||item.sos_cadastros?.latitude)&&(
                      <button className="btn btn-primary" style={{fontSize:10,padding:'3px 8px',marginLeft:'auto'}}
                        onClick={(e)=>{e.stopPropagation();handleTraceRoute(item);}}
                        disabled={loadingRoute}>
                        {loadingRoute?'...':'🗺️ Rota'}
                      </button>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      {/* ── MODAL DE DETALHE DO ALERTA ── */}
      {selFeed&&(()=>{
        const f=selFeed;const isSOS=f.tipo==='sos';const isDen=f.tipo==='den';const isOC=f.tipo==='oc';
        const cat=isDen?CAT_DEN[f.categoria]:isOC?CAT_OC[f.categoria]:null;
        const statusMap=isSOS?{ativo:{label:'Ativo',badge:'b-red'},resolvido:{label:'Resolvido',badge:'b-green'}}:isDen?S_DEN:S_OC;
        const st=statusMap[f.status]||{label:f.status||'—',badge:'b-gray'};
        const titulo=isSOS?'🚨 SOS Mulher':isDen?'📢 Denúncia':'⚠️ Ocorrência';
        const dataHora=f.created_at?new Date(f.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}):'';
        return(
          <div className="modal-overlay" onClick={()=>setSelFeed(null)}>
            <div className="modal-box" onClick={e=>e.stopPropagation()} style={{maxWidth:580}}>
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'18px 22px',borderBottom:'1px solid var(--border)',flexShrink:0}}>
                <div style={{display:'flex',alignItems:'center',gap:10}}>
                  <span style={{fontSize:15}}>{titulo}</span>
                  {f.protocolo&&<span className="mono" style={{fontSize:11,color:'var(--text-muted)'}}>{f.protocolo}</span>}
                  {cat&&<span className={`badge ${cat.badge}`} style={{fontSize:10}}>{cat.icon} {cat.label}</span>}
                </div>
                <button onClick={()=>setSelFeed(null)} style={{width:32,height:32,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--text-muted)',cursor:'pointer',borderRadius:8,border:'none',background:'none',fontSize:18}}>✕</button>
              </div>
              <div className="scrollable" style={{flex:1,padding:'20px 22px',minHeight:0}}>
                {/* Resumo / mensagem */}
                <p style={{fontSize:14,lineHeight:1.7,marginBottom:18,color:'var(--text)'}}>{f.mensagem||f.titulo||f.sos_cadastros?.nome||'Sem descrição'}</p>
                {/* Evidencias */}
                {f.midia_urls&&f.midia_urls.length>0&&(
                  <div style={{marginBottom:18}}>
                    <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:8}}>📎 Evidências ({f.midia_urls.length})</div>
                    <div style={{display:'grid',gridTemplateColumns:f.midia_urls.length===1?'1fr':'1fr 1fr',gap:8}}>
                      {f.midia_urls.map((url,i)=>{
                        const isVideo=/\.(mp4|mov|avi|webm)/i.test(url)||url.includes('video');
                        return isVideo?(
                          <div key={i} style={{borderRadius:10,overflow:'hidden',border:'1px solid var(--border)',background:'#000'}}>
                            <video src={url} controls muted playsInline style={{width:'100%',maxHeight:200,objectFit:'contain',display:'block'}}/>
                          </div>
                        ):(
                          <div key={i} style={{borderRadius:10,overflow:'hidden',border:'1px solid var(--border)',cursor:'pointer'}} onClick={()=>window.open(url,'_blank')}>
                            <img src={url} alt={`Evidência ${i+1}`} style={{width:'100%',maxHeight:200,objectFit:'cover',display:'block'}}/>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                )}
                {/* SOS: dados da vítima */}
                {isSOS&&f.sos_cadastros&&(
                  <div style={{marginBottom:18,padding:14,borderRadius:10,background:'rgba(220,38,38,.06)',border:'1px solid rgba(220,38,38,.15)'}}>
                    <div style={{fontSize:11,fontWeight:600,color:'#f87171',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Dados da Vítima</div>
                    {[
                      ['Nome',f.sos_cadastros.nome],
                      ['Telefone',f.sos_cadastros.telefone],
                      ['Endereço',f.sos_cadastros.endereco],
                      ['Agressor',f.sos_cadastros.nome_agressor],
                      ['Contato Confiança',f.sos_cadastros.contato_confianca],
                    ].filter(([,v])=>v).map(([l,v])=>(
                      <div key={l} style={{display:'flex',justifyContent:'space-between',padding:'6px 0',borderBottom:'1px solid rgba(220,38,38,.08)',fontSize:13}}>
                        <span style={{color:'var(--text-muted)'}}>{l}</span>
                        <span style={{fontWeight:500,color:'#fca5a5'}}>{v}</span>
                      </div>
                    ))}
                  </div>
                )}
                {/* Dados gerais */}
                <div style={{display:'grid',gap:8,fontSize:13,marginBottom:18}}>
                  {[
                    ['Status',st.label],
                    ['Data/Hora',dataHora],
                    f.bairro&&['Bairro',f.bairro],
                    f.endereco&&['Endereço',f.endereco],
                    !f.bairro&&!f.endereco&&f.latitude&&['Localização',`📍 ${Number(f.latitude).toFixed(5)}, ${Number(f.longitude).toFixed(5)}`],
                    isDen&&['Cidadania Ativa',f.cidadania_ativa?'✓ Sim':'Não'],
                    isDen&&f.valor_recompensa&&['Recompensa',`R$ ${Number(f.valor_recompensa).toLocaleString('pt-BR')}`],
                    isOC&&f.total_relatos&&['Relatos',f.total_relatos],
                    isOC&&['Severidade',f.severidade||'normal'],
                  ].filter(Boolean).map(([l,v])=>(
                    <div key={l} style={{display:'flex',justifyContent:'space-between',padding:'8px 12px',background:'rgba(255,255,255,.02)',borderRadius:8,border:'1px solid var(--border)'}}>
                      <span style={{color:'var(--text-muted)'}}>{l}</span>
                      <span style={{fontWeight:500,color:l==='Status'?({Ativo:'#f87171',Novo:'#3b82f6',Aberto:'#fbbf24',Procedente:'#4ade80'}[v]||'var(--text)'):l==='Cidadania Ativa'&&f.cidadania_ativa?'#4ade80':l==='Recompensa'?'#4ade80':'var(--text)'}}>{v}</span>
                    </div>
                  ))}
                </div>
                {/* Botões de ação */}
                <div style={{display:'flex',gap:8}}>
                  {(f.latitude||f.sos_cadastros?.latitude)&&(
                    <button className="btn btn-primary" style={{flex:1,justifyContent:'center'}}
                      onClick={()=>{handleTraceRoute(f);setSelFeed(null);}}>
                      🗺️ Traçar Rota no Mapa
                    </button>
                  )}
                  {isDen&&(
                    <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}}
                      onClick={async()=>{
                        try{
                          const res=await fetch(API_URL+'/api/denuncias/'+f.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'procedente',operador:'admin'})});
                          if(res.ok){alert('✅ Denúncia marcada como procedente!');setSelFeed(null);}
                          else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                        }catch(e){alert('Erro: '+e.message);}
                      }}>✓ Procedente</button>
                  )}
                  {isOC&&f.status==='aberto'&&(
                    <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}}
                      onClick={async()=>{
                        try{
                          const res=await fetch(API_URL+'/api/ocorrencias/'+f.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'em_atendimento'})});
                          if(res.ok){alert('✅ Equipe acionada!');setSelFeed(null);}
                          else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                        }catch(e){alert('Erro: '+e.message);}
                      }}>🚔 Acionar Equipe</button>
                  )}
                </div>
              </div>
            </div>
          </div>
        );
      })()}
    </div>
  );
}

/* ─── MAPA ─────────────────────────────────────────────────────── */
function Mapa(){
  const [modo,setModo]=useState('markers');
  const [f,setF]=useState('todos');
  const [catHeat,setCatHeat]=useState('todos');

  const isHeat=modo==='heatmap';

  // Categorias disponíveis para heatmap
  const HEAT_CATS=[
    {id:'todos',label:'Todas',icon:'🌐'},
    {id:'pichacao',label:'Pichação',icon:'🖊️'},
    {id:'trafico_drogas',label:'Tráfico',icon:'💊'},
    {id:'descarte_irregular',label:'Descarte Lixo',icon:'🗑️'},
    {id:'furto_fios',label:'Furto Fios',icon:'⚡'},
    {id:'depredacao',label:'Depredação',icon:'🔨'},
    {id:'queda_arvore',label:'Queda Árvore',icon:'🌳'},
    {id:'enchente_alagamento',label:'Enchente',icon:'🌊'},
    {id:'buraco_via',label:'Buraco',icon:'🕳️'},
    {id:'iluminacao_publica',label:'Iluminação',icon:'💡'},
    {id:'incendio',label:'Incêndio',icon:'🔥'},
  ];

  // Markers: ocorrências filtradas por status
  const items=OC.filter(o=>f==='todos'||o.status===f);
  const statusBtns=[['todos','Todos'],['aberto','Abertos'],['em_atendimento','Atendimento'],['resolvido','Resolvidos']];

  // Heatmap: combina denúncias + ocorrências, filtra por categoria
  const allPoints=[
    ...DEN.filter(d=>d.latitude&&d.longitude).map(d=>({lat:Number(d.latitude),lng:Number(d.longitude),categoria:d.categoria,weight:1.2})),
    ...OC.filter(o=>o.lat&&o.lng).map(o=>({lat:o.lat,lng:o.lng,categoria:o.categoria,weight:1})),
    ...SOS.filter(s=>s.latitude&&s.longitude).map(s=>({lat:Number(s.latitude),lng:Number(s.longitude),categoria:'sos',weight:1.5})),
  ];
  const heatPoints=catHeat==='todos'?allPoints:allPoints.filter(p=>p.categoria===catHeat);
  const totalPontos=heatPoints.length;

  return(
    <div style={{position:'relative',height:'100%'}}>
      {/* ── Barra superior: toggle modo + filtros ── */}
      <div style={{position:'absolute',top:16,left:16,zIndex:10,display:'flex',flexDirection:'column',gap:8}}>
        {/* Toggle markers / heatmap */}
        <div style={{display:'flex',gap:4,background:'rgba(18,18,18,0.92)',backdropFilter:'blur(12px)',border:'1px solid var(--border)',borderRadius:8,padding:4}}>
          <button onClick={()=>setModo('markers')} className="btn" style={{
            background:!isHeat?'var(--accent)':'transparent',border:'none',
            color:!isHeat?'#fff':'var(--text-secondary)',fontSize:12,padding:'6px 12px',
          }}>📍 Markers</button>
          <button onClick={()=>setModo('heatmap')} className="btn" style={{
            background:isHeat?'#dc2626':'transparent',border:'none',
            color:isHeat?'#fff':'var(--text-secondary)',fontSize:12,padding:'6px 12px',
          }}>🔥 Heatmap</button>
        </div>
        {/* Filtros contextuais */}
        {!isHeat?(
          <div style={{display:'flex',gap:4}}>
            {statusBtns.map(([k,l])=>(
              <button key={k} onClick={()=>setF(k)} className="btn" style={{
                background:f===k?'var(--accent)':'rgba(18,18,18,0.9)',
                border:`1px solid ${f===k?'var(--accent)':'var(--border)'}`,
                color:f===k?'#fff':'var(--text-secondary)',
                backdropFilter:'blur(12px)',fontSize:12,padding:'5px 10px',
              }}>{l}</button>
            ))}
          </div>
        ):(
          <div style={{display:'flex',flexWrap:'wrap',gap:4,maxWidth:480}}>
            {HEAT_CATS.map(c=>(
              <button key={c.id} onClick={()=>setCatHeat(c.id)} className="btn" style={{
                background:catHeat===c.id?'rgba(220,38,38,0.8)':'rgba(18,18,18,0.9)',
                border:`1px solid ${catHeat===c.id?'#dc2626':'var(--border)'}`,
                color:catHeat===c.id?'#fff':'var(--text-secondary)',
                backdropFilter:'blur(12px)',fontSize:11,padding:'4px 9px',
              }}>{c.icon} {c.label}</button>
            ))}
          </div>
        )}
      </div>
      {/* ── Contador ── */}
      <div style={{position:'absolute',top:16,right:16,zIndex:10,background:'rgba(18,18,18,0.92)',backdropFilter:'blur(12px)',border:'1px solid var(--border)',borderRadius:8,padding:'14px 20px',textAlign:'center'}}>
        <div className="mono" style={{fontSize:28,fontWeight:600,color:isHeat?'#f87171':'#fff'}}>{isHeat?totalPontos:items.length}</div>
        <div style={{fontSize:10,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'1px',marginTop:3}}>{isHeat?'Pontos no Mapa':'Ocorrências'}</div>
        {isHeat&&catHeat!=='todos'&&<div style={{fontSize:11,color:'#f87171',marginTop:4,fontWeight:500}}>{HEAT_CATS.find(c=>c.id===catHeat)?.icon} {HEAT_CATS.find(c=>c.id===catHeat)?.label}</div>}
      </div>
      <MapboxMap items={isHeat?[]:items} fullscreen={true} heatmapData={isHeat?heatPoints:null} heatmapMode={isHeat}/>
    </div>
  );
}

/* ─── OCORRÊNCIAS ──────────────────────────────────────────────── */
function Ocorrencias(){
  const [sel,setSel]=useState(null);
  const [f,setF]=useState('ativas');
  const [routeData,setRouteData]=useState(null);
  const [routeBase,setRouteBase]=useState(null);
  const [routeIncident,setRouteIncident]=useState(null);
  const [loadingRoute,setLoadingRoute]=useState(false);

  async function handleTraceRoute(item){
    setLoadingRoute(true);
    const base=nearestBase(item.lat,item.lng,'gcm');
    if(!base){setLoadingRoute(false);return;}
    const r=await fetchRoute(base.lng,base.lat,item.lng,item.lat);
    if(r){setRouteData(r);setRouteBase(base);setRouteIncident(item);}
    setLoadingRoute(false);
  }

  const lista=OC.filter(o=>f==='ativas'?o.status!=='resolvido':f==='resolvido'?o.status==='resolvido':true);
  return(
    <div style={{display:'flex',height:'100%',overflow:'hidden',position:'relative'}}>
      <div style={{width:380,flexShrink:0,borderRight:'1px solid var(--border)',display:'flex',flexDirection:'column',background:'var(--surface)'}}>
        <div style={{padding:'16px',borderBottom:'1px solid var(--border)'}}>
          <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:12}}>
            <span style={{fontWeight:600,fontSize:16,color:'#fff'}}>Ocorrências</span>
            <span style={{fontSize:13,color:'var(--text-muted)'}}>{lista.length} {f==='ativas'?'ativas':'total'}</span>
          </div>
          <select value={f} onChange={e=>setF(e.target.value)} style={{width:'100%'}}>
            <option value="ativas">Ativas</option>
            <option value="resolvido">Resolvidas</option>
            <option value="todas">Todas</option>
          </select>
        </div>
        <div className="scrollable" style={{flex:1}}>
          {lista.map(o=>{
            const cat=CAT_OC[o.categoria]||{label:o.categoria,icon:'📌',c:'#8b949e'};
            const sev=SEV[o.severidade]||SEV.baixa;
            const sta=S_OC[o.status]||{label:o.status,badge:'b-gray'};
            const isSel=sel?.id===o.id;
            return(
              <div key={o.id} onClick={()=>setSel(isSel?null:o)} style={{padding:'14px 16px',borderBottom:'1px solid var(--border)',cursor:'pointer',background:isSel?'rgba(5,150,105,.06)':'transparent',borderLeft:`3px solid ${isSel?'var(--accent)':'transparent'}`,transition:'all .12s'}}>
                <div style={{display:'flex',alignItems:'flex-start',justifyContent:'space-between',marginBottom:8}}>
                  <div style={{display:'flex',alignItems:'center',gap:10,flex:1,minWidth:0}}>
                    <div style={{width:36,height:36,borderRadius:8,background:cat.c+'15',display:'flex',alignItems:'center',justifyContent:'center',fontSize:16,flexShrink:0}}>{cat.icon}</div>
                    <div style={{minWidth:0}}>
                      <div className="truncate" style={{fontSize:14,fontWeight:600,color:'var(--text)',lineHeight:1.3}}>{o.titulo}</div>
                      <div style={{display:'flex',alignItems:'center',gap:4,marginTop:3,color:'var(--text-muted)',fontSize:12}}><Ico.pin/>{o.bairro}</div>
                    </div>
                  </div>
                  <div style={{display:'flex',alignItems:'center',gap:4,flexShrink:0}}>
                    <div style={{width:6,height:6,borderRadius:'50%',background:sev.dot}}/>
                    <span style={{fontSize:11,color:sev.c,fontWeight:500}}>{sev.label}</span>
                  </div>
                </div>
                <div style={{display:'flex',alignItems:'center',justifyContent:'space-between'}}>
                  <span className={`badge ${sta.badge}`}>{sta.label}</span>
                  <span style={{fontSize:11,color:'var(--text-muted)'}}>{ago(o.created_at)}</span>
                </div>
                {o.total_relatos>1&&(
                  <div style={{marginTop:8,background:'rgba(5,150,105,.06)',border:'1px solid rgba(5,150,105,.15)',borderRadius:6,padding:'5px 10px',fontSize:12,color:'#4ade80'}}>
                    👥 {o.total_relatos} cidadãos reportaram
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
      <div style={{flex:1,display:'flex',flexDirection:'column',overflow:'hidden',position:'relative'}}>
        <div style={{flex:1,minHeight:0}}>
          <MapboxMap items={lista} showBases={true} route={routeData}/>
          {routeData&&<RoutePanel route={routeData} base={routeBase} incident={routeIncident} onClose={()=>{setRouteData(null);setRouteBase(null);setRouteIncident(null);}}/>}
        </div>
        {sel&&(
          <div className="card" style={{margin:16,padding:18,borderColor:'rgba(5,150,105,.25)',background:'rgba(5,150,105,.03)'}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:12}}>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontWeight:600,fontSize:16,color:'#fff'}}>{sel.titulo}</div>
                <div className="mono" style={{fontSize:12,color:'var(--text-muted)',marginTop:3}}>{sel.protocolo}</div>
              </div>
              <div style={{display:'flex',gap:8,alignItems:'center',flexShrink:0}}>
                {sel.status==='aberto'&&(
                  <button className="btn btn-outline" onClick={async()=>{
                    try{
                      const res=await fetch(API_URL+'/api/ocorrencias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'equipe_caminho'})});
                      if(res.ok){setSel(prev=>({...prev,status:'equipe_caminho'}));}
                      else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                    }catch(e){alert('Erro: '+e.message);}
                  }}>🚔 Acionar Equipe</button>
                )}
                {sel.status==='equipe_caminho'&&(
                  <button className="btn btn-outline" onClick={async()=>{
                    try{
                      const res=await fetch(API_URL+'/api/ocorrencias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'em_atendimento'})});
                      if(res.ok){setSel(prev=>({...prev,status:'em_atendimento'}));}
                      else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                    }catch(e){alert('Erro: '+e.message);}
                  }}>🔧 Em Atendimento</button>
                )}
                {sel.status!=='resolvido'&&(
                  <button className="btn btn-primary" onClick={async()=>{
                    if(!confirm('Marcar ocorrência como resolvida?')) return;
                    try{
                      const res=await fetch(API_URL+'/api/ocorrencias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'resolvido'})});
                      if(res.ok){setSel(prev=>({...prev,status:'resolvido'}));}
                      else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                    }catch(e){alert('Erro: '+e.message);}
                  }}>Resolver ✓</button>
                )}
                <button className="btn" style={{background:'var(--accent)',color:'#fff',border:'none'}}
                  onClick={()=>handleTraceRoute(sel)}
                  disabled={loadingRoute}>
                  {loadingRoute?'Calculando...':'🗺️ Traçar Rota'}
                </button>
                <button onClick={()=>setSel(null)} style={{background:'none',border:'none',color:'var(--text-muted)',cursor:'pointer',fontSize:18,padding:4}}>✕</button>
              </div>
            </div>
            <div style={{display:'flex',gap:12,alignItems:'center',flexWrap:'wrap'}}>
              <span className={`badge ${(S_OC[sel.status]||{}).badge||'b-gray'}`}>{(S_OC[sel.status]||{}).label||sel.status}</span>
              <span className="badge b-green">{sel.total_relatos} cidadãos</span>
              <span className={`badge ${SEV[sel.severidade]?'b-warn':'b-gray'}`}>{SEV[sel.severidade]?.label||sel.severidade}</span>
              <span style={{fontSize:13,color:'var(--text-muted)'}}>{sel.bairro}</span>
            </div>
            {(sel.descricao||sel.endereco)&&(
              <div style={{marginTop:10,fontSize:13,color:'var(--text-muted)',lineHeight:1.5}}>
                {sel.descricao&&<div style={{marginBottom:4}}>{sel.descricao}</div>}
                {sel.endereco&&<div style={{display:'flex',alignItems:'center',gap:4}}>📍 {sel.endereco}</div>}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

/* ─── DENÚNCIAS ────────────────────────────────────────────────── */
function Denuncias(){
  const [tab,setTab]=useState('lista');
  const [sel,setSel]=useState(null);
  const [fc,setFc]=useState('');
  const lista=DEN.filter(d=>!fc||d.categoria===fc);
  const pago=DEN.filter(d=>d.status==='recompensa_paga').reduce((a,d)=>a+(d.valor_recompensa||0),0);
  const apagar=DEN.filter(d=>d.status==='procedente').reduce((a,d)=>a+(d.valor_recompensa||0),0);
  const analise=DEN.filter(d=>d.status==='em_analise').reduce((a,d)=>a+(d.valor_recompensa||0),0);
  const chartData=[{label:'Out',oc:34,den:12},{label:'Nov',oc:41,den:18},{label:'Dez',oc:29,den:9},{label:'Jan',oc:52,den:22},{label:'Fev',oc:38,den:15},{label:'Mar',oc:47,den:19}];
  const recompData=[{label:'Jan',pago:2400,apagar:800},{label:'Fev',pago:1800,apagar:600},{label:'Mar',pago:3200,apagar:1200}];
  const pieData=[{v:2,c:'#dc2626',n:'Tráfico'},{v:2,c:'#7c3aed',n:'Pichação'},{v:1,c:'#fbbf24',n:'Descarte'},{v:1,c:'#3b82f6',n:'Furto Fios'}];

  return(
    <div style={{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}}>
      <div className="stat-row">
        {[
          {num:`R$ ${pago.toLocaleString('pt-BR')}`,lbl:'Total Pago',c:'#4ade80'},
          {num:`R$ ${apagar.toLocaleString('pt-BR')}`,lbl:'A Pagar',c:'#fbbf24'},
          {num:`R$ ${analise.toLocaleString('pt-BR')}`,lbl:'Em Análise',c:'#3b82f6'},
          {num:`R$ ${(pago+apagar+analise).toLocaleString('pt-BR')}`,lbl:'Total Geral',c:'#fff'},
          {num:DEN.length,lbl:'Denúncias',c:'#3b82f6'},
          {num:DEN.filter(d=>d.cidadania_ativa).length,lbl:'Cidadania Ativa',c:'#4ade80'},
        ].map((s,i)=>(
          <div key={i} className="stat-box anim-card">
            <div className="stat-num" style={{color:s.c}}>{s.num}</div>
            <div className="stat-lbl">{s.lbl}</div>
          </div>
        ))}
      </div>
      <div className="tab-bar">
        <div className={`tab ${tab==='lista'?'active':''}`} onClick={()=>setTab('lista')}>Denúncias</div>
        <div className={`tab ${tab==='graficos'?'active':''}`} onClick={()=>setTab('graficos')}>Gráficos</div>
        <div className="tab-spacer"/>
        <div style={{display:'flex',alignItems:'flex-end',paddingBottom:10}}>
          <select value={fc} onChange={e=>setFc(e.target.value)}>
            <option value="">Todas categorias</option>
            {Object.entries(CAT_DEN).map(([k,v])=><option key={k} value={k}>{v.icon} {v.label}</option>)}
          </select>
        </div>
      </div>
      {tab==='lista'?(
        <div className="scrollable" style={{flex:1}}>
          <table>
            <thead><tr><th>Protocolo</th><th>Categoria</th><th>Mensagem</th><th>Bairro</th><th>Status</th><th>Recompensa</th><th>Recebido</th></tr></thead>
            <tbody>
              {lista.map(d=>{
                const cat=CAT_DEN[d.categoria]||{label:d.categoria,icon:'📌',badge:'b-gray'};
                const sta=S_DEN[d.status]||{label:d.status,badge:'b-gray'};
                return(
                  <tr key={d.id} onClick={()=>setSel(d)} style={{cursor:'pointer',background:sel?.id===d.id?'rgba(5,150,105,.04)':''}}>
                    <td><span className="mono" style={{fontSize:12,color:'var(--text-muted)'}}>{d.protocolo}</span>{d.midia_urls&&d.midia_urls.length>0&&<span title={`${d.midia_urls.length} evidência(s)`} style={{marginLeft:6,fontSize:11,opacity:.7}}>📎</span>}</td>
                    <td><span className={`badge ${cat.badge}`}>{cat.icon} {cat.label}</span></td>
                    <td style={{maxWidth:280}}><span className="truncate" style={{display:'block',maxWidth:280}}>{d.mensagem}</span></td>
                    <td>{d.bairro}</td>
                    <td><span className={`badge ${sta.badge}`}>{sta.label}</span></td>
                    <td>{d.valor_recompensa?<span className="mono" style={{fontWeight:600,color:'#4ade80'}}>R$ {d.valor_recompensa.toLocaleString('pt-BR')}</span>:<span style={{color:'var(--text-muted)'}}>—</span>}</td>
                    <td style={{color:'var(--text-muted)',fontSize:12}}>{ago(d.created_at)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ):(
        <div className="scrollable" style={{flex:1,padding:20}}>
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16}}>
            <div className="chart-card anim-card"><div className="chart-title">Ocorrências × Denúncias · 6 meses</div><AreaChart data={chartData} keys={['oc','den']} colors={['#3b82f6','#059669']} height={240}/><div className="chart-legend"><div className="chart-legend-item"><div style={{width:10,height:3,borderRadius:2,background:'#3b82f6'}}/>Ocorrências</div><div className="chart-legend-item"><div style={{width:10,height:3,borderRadius:2,background:'#059669'}}/>Denúncias</div></div></div>
            <div className="chart-card anim-card"><div className="chart-title">Distribuição por Categoria</div><div style={{display:'flex',alignItems:'center',gap:28,flex:1,justifyContent:'center'}}><DonutChart data={pieData} size={170}/><div style={{display:'flex',flexDirection:'column',gap:12}}>{pieData.map((d,i)=>(<div key={i} style={{display:'flex',alignItems:'center',gap:10,fontSize:13}}><div style={{width:10,height:10,borderRadius:3,background:d.c}}/><span style={{color:'var(--text-muted)',minWidth:70}}>{d.n}</span><span className="mono" style={{fontWeight:600,color:'#fff'}}>{d.v}</span></div>))}</div></div></div>
            <div className="chart-card anim-card"><div className="chart-title">Recompensas Pagas × A Pagar</div><BarChart data={recompData} keys={['pago','apagar']} colors={['#059669','#fbbf24']} height={240}/><div className="chart-legend"><div className="chart-legend-item"><div style={{width:10,height:10,borderRadius:3,background:'#059669'}}/>Pago</div><div className="chart-legend-item"><div style={{width:10,height:10,borderRadius:3,background:'#fbbf24'}}/>A Pagar</div></div></div>
            <div className="chart-card anim-card"><div className="chart-title">Resumo Financeiro</div><div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12,flex:1,alignContent:'center'}}>{[['Pago','R$ '+pago.toLocaleString('pt-BR'),'#4ade80'],['A Pagar','R$ '+apagar.toLocaleString('pt-BR'),'#fbbf24'],['Em Análise','R$ '+analise.toLocaleString('pt-BR'),'#3b82f6'],['Total','R$ '+(pago+apagar+analise).toLocaleString('pt-BR'),'#fff']].map(([l,v,c])=>(<div key={l} style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:8,padding:'16px 18px'}}><div className="mono" style={{fontSize:20,fontWeight:600,color:c}}>{v}</div><div style={{fontSize:10,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginTop:5}}>{l}</div></div>))}</div></div>
          </div>
        </div>
      )}
      {sel&&(
        <div className="modal-overlay" onClick={()=>setSel(null)}>
          <div className="modal-box" onClick={e=>e.stopPropagation()}>
            <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'18px 22px',borderBottom:'1px solid var(--border)',flexShrink:0}}>
              <div style={{display:'flex',alignItems:'center',gap:12}}>
                <span className="mono" style={{fontSize:12,color:'var(--text-muted)'}}>{sel.protocolo}</span>
                <span className={`badge ${CAT_DEN[sel.categoria]?.badge||'b-gray'}`}>{CAT_DEN[sel.categoria]?.icon} {CAT_DEN[sel.categoria]?.label}</span>
              </div>
              <button onClick={()=>setSel(null)} style={{width:32,height:32,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--text-muted)',cursor:'pointer',borderRadius:8,border:'none',background:'none',fontSize:18}}>✕</button>
            </div>
            <div className="scrollable" style={{flex:1,padding:'20px 22px',minHeight:0}}>
              <p style={{fontSize:14,lineHeight:1.7,marginBottom:22,color:'var(--text)'}}>{sel.mensagem}</p>
              {sel.midia_urls&&sel.midia_urls.length>0&&(
                <div style={{marginBottom:22}}>
                  <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10,display:'flex',alignItems:'center',gap:6}}>
                    <span style={{fontSize:14}}>📎</span> Evidências ({sel.midia_urls.length})
                  </div>
                  <div style={{display:'grid',gridTemplateColumns:sel.midia_urls.length===1?'1fr':'1fr 1fr',gap:10}}>
                    {sel.midia_urls.map((url,i)=>{
                      const isVideo=/\.(mp4|mov|avi|webm)/i.test(url)||url.includes('video');
                      return isVideo?(
                        <div key={i} style={{position:'relative',borderRadius:10,overflow:'hidden',border:'1px solid var(--border)',background:'#000'}}>
                          <video src={url} controls muted playsInline style={{width:'100%',maxHeight:240,objectFit:'contain',display:'block'}}/>
                          <div style={{position:'absolute',top:8,left:8,background:'rgba(0,0,0,.75)',color:'#fbbf24',fontSize:11,fontWeight:700,padding:'3px 8px',borderRadius:4,display:'flex',alignItems:'center',gap:4}}>
                            🎥 Vídeo
                          </div>
                        </div>
                      ):(
                        <div key={i} style={{position:'relative',borderRadius:10,overflow:'hidden',border:'1px solid var(--border)',cursor:'pointer'}} onClick={()=>window.open(url,'_blank')}>
                          <img src={url} alt={`Evidência ${i+1}`} style={{width:'100%',maxHeight:240,objectFit:'cover',display:'block'}}/>
                          <div style={{position:'absolute',bottom:0,left:0,right:0,padding:'8px 10px',background:'linear-gradient(transparent,rgba(0,0,0,.8))',display:'flex',alignItems:'center',justifyContent:'space-between'}}>
                            <span style={{color:'#fff',fontSize:11,fontWeight:600,display:'flex',alignItems:'center',gap:4}}>📸 Foto {sel.midia_urls.length>1?i+1:''}</span>
                            <span style={{color:'var(--accent-light)',fontSize:10,fontWeight:600}}>Ampliar ↗</span>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
              <div style={{display:'grid',gap:10,fontSize:13,marginBottom:24}}>
                {[
                  ['Bairro',sel.bairro||(sel.latitude?`📍 GPS: ${Number(sel.latitude).toFixed(4)}, ${Number(sel.longitude).toFixed(4)}`:'Não informado')],
                  sel.endereco&&['Endereço',sel.endereco],
                  ['Cidadania Ativa',sel.cidadania_ativa?'✓ Sim':'Não'],
                  sel.valor_recompensa&&['Recompensa',`R$ ${sel.valor_recompensa.toLocaleString('pt-BR')}`],
                  ['Status',S_DEN[sel.status]?.label||sel.status],
                ].filter(Boolean).map(([l,v])=>(
                  <div key={l} style={{display:'flex',justifyContent:'space-between',padding:'10px 14px',background:'rgba(255,255,255,.02)',borderRadius:8,border:'1px solid var(--border)'}}>
                    <span style={{color:'var(--text-muted)'}}>{l}</span>
                    <span style={{fontWeight:500,color:l==='Cidadania Ativa'&&sel.cidadania_ativa?'#4ade80':l==='Recompensa'?'#4ade80':'var(--text)'}}>{v}</span>
                  </div>
                ))}
              </div>
              <div style={{display:'flex',gap:10}}>
                <button className="btn btn-primary" style={{flex:1,justifyContent:'center'}} onClick={async()=>{
                  try{
                    const res=await fetch(API_URL+'/api/denuncias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'procedente',operador:'admin'})});
                    if(res.ok){alert('✅ Denúncia marcada como procedente!');setSel(null);}
                    else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                  }catch(e){alert('Erro: '+e.message);}
                }}>✓ Procedente</button>
                <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}} onClick={async()=>{
                  const destino=prompt('Encaminhar para qual órgão?\n\n1 - Polícia Civil\n2 - Guarda Municipal\n3 - Meio Ambiente\n4 - Fiscalização\n\nDigite o número:');
                  const orgaos={'1':'Polícia Civil','2':'Guarda Municipal','3':'Meio Ambiente','4':'Fiscalização'};
                  const orgao=orgaos[destino];
                  if(!orgao){if(destino!==null)alert('Opção inválida.');return;}
                  try{
                    const res=await fetch(API_URL+'/api/denuncias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'encaminhada',operador:'admin',notas:'Encaminhada para: '+orgao})});
                    if(res.ok){alert('✅ Denúncia encaminhada para '+orgao+'!');setSel(null);}
                    else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                  }catch(e){alert('Erro: '+e.message);}
                }}>→ Encaminhar</button>
                <button className="btn btn-danger" style={{flex:1,justifyContent:'center'}} onClick={async()=>{
                  const motivo=prompt('Motivo (opcional):');
                  try{
                    const res=await fetch(API_URL+'/api/denuncias/'+sel.id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'improcedente',operador:'admin',notas:motivo||''})});
                    if(res.ok){alert('Denúncia marcada como improcedente.');setSel(null);}
                    else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
                  }catch(e){alert('Erro: '+e.message);}
                }}>✕ Improcedente</button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── SOS MULHER ───────────────────────────────────────────────── */
function SOSMulher(){
  const [sel,setSel]=useState(SOS[0]);
  const [routeData,setRouteData]=useState(null);
  const [routeBase,setRouteBase]=useState(null);
  const [routeIncident,setRouteIncident]=useState(null);
  const [loadingRoute,setLoadingRoute]=useState(false);
  const [notas,setNotas]=useState('');
  const [salvandoNotas,setSalvandoNotas]=useState(false);
  const [histModal,setHistModal]=useState(null);

  // Atualiza notas quando muda a seleção
  useEffect(()=>{setNotas(sel?.notas||'');},[sel?.id]);

  async function handleTraceRoute(item){
    setLoadingRoute(true);
    const base=nearestBase(item.lat,item.lng,'pm');
    if(!base){setLoadingRoute(false);return;}
    const r=await fetchRoute(base.lng,base.lat,item.lng,item.lat);
    if(r){setRouteData(r);setRouteBase(base);setRouteIncident({...item,severidade:'critica',titulo:'SOS: '+(item.sos_cadastros?.nome||item.telefone)});}
    setLoadingRoute(false);
  }

  async function handleAceitar(){
    if(!sel) return;
    try{
      const res=await fetch(API_URL+'/api/sos/alertas/'+sel.id+'/aceitar',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({operador:'admin'})});
      if(res.ok){alert('✅ Atendimento aceito! Sirene desativada.');setSel(prev=>({...prev,status:'attending'}));}
      else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
    }catch(e){alert('Erro: '+e.message);}
  }

  async function handleResolver(){
    if(!sel) return;
    const motivo=prompt('Notas de resolução (opcional):');
    try{
      const res=await fetch(API_URL+'/api/sos/alertas/'+sel.id+'/resolver',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({notas:motivo||notas||''})});
      if(res.ok){alert('✅ Alerta resolvido.');setSel(null);}
      else{const err=await res.json().catch(()=>({}));alert('Erro: '+(err.detail||res.statusText));}
    }catch(e){alert('Erro: '+e.message);}
  }

  async function handleSalvarNotas(){
    if(!sel) return;
    setSalvandoNotas(true);
    try{
      await fetch(API_URL+'/api/sos/alertas/'+sel.id+'/notas',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({notas})});
    }catch(e){}
    setSalvandoNotas(false);
  }

  const isAttending=sel?.status==='attending';

  return(
    <div style={{display:'flex',height:'100%',overflow:'hidden',position:'relative'}}>
      {/* ── SIDEBAR ESQUERDA ── */}
      <div style={{width:300,flexShrink:0,borderRight:'1px solid var(--border)',display:'flex',flexDirection:'column',background:'var(--surface)'}}>
        <div style={{padding:'16px 16px 10px'}}>
          <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:12}}>
            <div style={{width:8,height:8,borderRadius:'50%',background:'#dc2626',animation:'pulse 1s infinite'}}/>
            <span style={{fontSize:12,fontWeight:600,color:'#dc2626',textTransform:'uppercase',letterSpacing:'1px'}}>Alertas Ativos</span>
            <span className="nav-badge" style={{marginLeft:'auto'}}>{SOS.length}</span>
          </div>
        </div>
        <div className="scrollable" style={{flex:1,minHeight:0}}>
          {SOS.length===0&&(
            <div style={{padding:'20px 16px',textAlign:'center',color:'var(--text-muted)',fontSize:13}}>Nenhum alerta ativo</div>
          )}
          {SOS.map(s=>{
            const isAtt=s.status==='attending';
            return(
              <div key={s.id} onClick={()=>setSel(s)} style={{margin:'0 10px 6px',padding:'14px 16px',borderRadius:8,background:sel?.id===s.id?'rgba(220,38,38,.08)':isAtt?'rgba(251,191,36,.05)':'rgba(220,38,38,.03)',border:`1px solid ${sel?.id===s.id?'rgba(220,38,38,.3)':isAtt?'rgba(251,191,36,.2)':'rgba(220,38,38,.12)'}`,cursor:'pointer'}}>
                <div style={{display:'flex',justifyContent:'space-between',marginBottom:4}}>
                  <span style={{fontWeight:600,fontSize:14,color:'#fff'}}>{s.sos_cadastros?.nome||s.telefone}</span>
                  <span style={{fontSize:12,color:isAtt?'#fbbf24':'#f87171'}}>{ago(s.created_at)}</span>
                </div>
                <div style={{fontSize:12,color:'var(--text-secondary)',marginBottom:4}}>{s.sos_cadastros?.endereco||'Endereço não informado'}</div>
                <span className={`badge ${isAtt?'b-warn':'b-red'}`} style={{fontSize:10}}>{isAtt?'Em atendimento':'Aguardando'}</span>
              </div>
            );
          })}
          {/* Histórico real */}
          {SOS_HIST.length>0&&(
            <>
              <div style={{height:1,background:'var(--border)',margin:'14px 14px 10px'}}/>
              <div style={{padding:'0 16px 6px',fontSize:10,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'1px'}}>Histórico ({SOS_HIST.length})</div>
              {SOS_HIST.slice(0,15).map(h=>(
                <div key={h.id} onClick={()=>setHistModal(h)} style={{padding:'10px 16px',borderBottom:'1px solid var(--border)',cursor:'pointer',transition:'background .1s'}}
                  onMouseEnter={e=>e.currentTarget.style.background='rgba(74,222,128,.04)'}
                  onMouseLeave={e=>e.currentTarget.style.background='transparent'}>
                  <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                    <span style={{fontSize:13,color:'var(--text)',fontWeight:500}}>{h.sos_cadastros?.nome||h.telefone}</span>
                    <span className="badge b-green" style={{fontSize:10}}>Resolvido</span>
                  </div>
                  <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginTop:4}}>
                    <span style={{fontSize:11,color:'var(--text-muted)'}}>{h.sos_cadastros?.endereco||'—'}</span>
                    <span style={{fontSize:10,color:'var(--text-muted)',fontFamily:'var(--font-mono)'}}>{h.resolvido_em?new Date(h.resolvido_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}):''}</span>
                  </div>
                </div>
              ))}
            </>
          )}
        </div>
      </div>
      {/* ── CONTEÚDO PRINCIPAL ── */}
      {/* ── MODAL HISTÓRICO ── */}
      {histModal&&(()=>{
        const h=histModal;
        const cad=h.sos_cadastros;
        const criadoEm=h.created_at?new Date(h.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',second:'2-digit'}):'—';
        const resolvidoEm=h.resolvido_em?new Date(h.resolvido_em).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',second:'2-digit'}):'—';
        const duracao=(()=>{
          if(!h.created_at||!h.resolvido_em) return '—';
          const ms=new Date(h.resolvido_em)-new Date(h.created_at);
          const min=Math.floor(ms/60000);
          if(min<60) return `${min} min`;
          const hrs=Math.floor(min/60);
          return `${hrs}h ${min%60}min`;
        })();
        return(
          <div className="modal-overlay" onClick={()=>setHistModal(null)}>
            <div className="modal-box" onClick={e=>e.stopPropagation()} style={{maxWidth:620}}>
              {/* Header */}
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'18px 22px',borderBottom:'1px solid var(--border)',flexShrink:0}}>
                <div style={{display:'flex',alignItems:'center',gap:10}}>
                  <span style={{fontSize:18}}>🛡️</span>
                  <div>
                    <div style={{fontSize:16,fontWeight:700,color:'#fff'}}>{cad?.nome||h.telefone}</div>
                    <span className="badge b-green" style={{fontSize:10,marginTop:4}}>Resolvido</span>
                  </div>
                </div>
                <button onClick={()=>setHistModal(null)} style={{width:32,height:32,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--text-muted)',cursor:'pointer',borderRadius:8,border:'none',background:'none',fontSize:18}}>✕</button>
              </div>
              {/* Body */}
              <div className="scrollable" style={{flex:1,padding:'20px 22px',minHeight:0}}>
                {/* Timeline */}
                <div style={{marginBottom:22}}>
                  <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:12}}>Linha do Tempo</div>
                  <div style={{position:'relative',paddingLeft:24}}>
                    <div style={{position:'absolute',left:7,top:6,bottom:6,width:2,background:'var(--border)'}}/>
                    {[
                      {icon:'🚨',color:'#dc2626',label:'Alerta Recebido',detail:`Código: "${h.codigo_usado||'—'}"`,time:criadoEm},
                      h.atendido_por&&{icon:'🔔',color:'#fbbf24',label:'Atendimento Aceito',detail:`Operador: ${h.atendido_por}`,time:''},
                      h.latitude&&{icon:'📍',color:'#3b82f6',label:'Localização Recebida',detail:`${Number(h.latitude).toFixed(5)}, ${Number(h.longitude).toFixed(5)}`,time:''},
                      {icon:'✅',color:'#4ade80',label:'Caso Resolvido',detail:`Duração total: ${duracao}`,time:resolvidoEm},
                    ].filter(Boolean).map((ev,i)=>(
                      <div key={i} style={{display:'flex',gap:12,marginBottom:16,position:'relative'}}>
                        <div style={{width:16,height:16,borderRadius:'50%',background:ev.color,display:'flex',alignItems:'center',justifyContent:'center',fontSize:9,flexShrink:0,zIndex:1,border:'2px solid var(--bg)'}}/>
                        <div style={{flex:1}}>
                          <div style={{fontSize:13,fontWeight:600,color:'var(--text)'}}>{ev.label}</div>
                          <div style={{fontSize:12,color:'var(--text-muted)',marginTop:2}}>{ev.detail}</div>
                          {ev.time&&<div style={{fontSize:11,color:'var(--text-muted)',fontFamily:'var(--font-mono)',marginTop:2}}>{ev.time}</div>}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
                {/* Dados da vítima */}
                {cad&&(
                  <div style={{marginBottom:22}}>
                    <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Dados da Vítima</div>
                    <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:8}}>
                      {[
                        ['Nome',cad.nome],
                        ['Telefone',h.telefone],
                        ['Endereço',cad.endereco],
                        ['Referência',cad.referencia],
                        ['Agressor',cad.agressor],
                        cad.contato_confianca_nome&&['Contato Confiança',`${cad.contato_confianca_nome} — ${cad.contato_confianca_telefone||''}`],
                      ].filter(Boolean).filter(([,v])=>v).map(([l,v])=>(
                        <div key={l} style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:8,padding:'10px 12px'}}>
                          <div style={{fontSize:10,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.5px',marginBottom:3}}>{l}</div>
                          <div style={{fontSize:13,color:l==='Agressor'?'#f87171':'var(--text)',fontWeight:500,wordBreak:'break-word'}}>{v}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
                {/* Notas */}
                {h.notas&&(
                  <div style={{marginBottom:22}}>
                    <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Notas do Operador</div>
                    <div style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:8,padding:'14px 16px',fontSize:13,color:'var(--text)',lineHeight:1.7,whiteSpace:'pre-wrap'}}>{h.notas}</div>
                  </div>
                )}
                {/* Sem cadastro */}
                {!cad&&(
                  <div style={{background:'rgba(251,191,36,.04)',border:'1px solid rgba(251,191,36,.15)',borderRadius:8,padding:'14px 16px',marginBottom:22}}>
                    <div style={{fontSize:13,color:'#fbbf24',fontWeight:500}}>⚠️ Vítima não cadastrada no programa</div>
                    <div style={{fontSize:12,color:'var(--text-muted)',marginTop:4}}>Telefone: {h.telefone}</div>
                    <div style={{fontSize:12,color:'var(--text-muted)',marginTop:2}}>Esta pessoa não possui cadastro no Mulher Segura. Os dados como nome, endereço e agressor não estão disponíveis.</div>
                  </div>
                )}
                {/* Localização */}
                {h.latitude&&(
                  <div>
                    <div style={{fontSize:11,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Localização Registrada</div>
                    <a href={`https://www.google.com/maps?q=${h.latitude},${h.longitude}`} target="_blank" rel="noopener"
                      style={{display:'flex',alignItems:'center',gap:8,background:'rgba(59,130,246,.06)',border:'1px solid rgba(59,130,246,.15)',borderRadius:8,padding:'12px 16px',textDecoration:'none',color:'#60a5fa',fontSize:13,fontWeight:500}}>
                      📍 Ver no Google Maps — {Number(h.latitude).toFixed(5)}, {Number(h.longitude).toFixed(5)}
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        );
      })()}
      {sel?(
        <div style={{flex:1,display:'flex',flexDirection:'column',overflow:'hidden'}}>
          {/* Cabeçalho da vítima */}
          <div style={{flexShrink:0,padding:'16px 20px',borderBottom:'1px solid var(--border)',background:'var(--surface)'}}>
            <div style={{background:isAttending?'rgba(251,191,36,.04)':'rgba(220,38,38,.04)',border:`1px solid ${isAttending?'rgba(251,191,36,.18)':'rgba(220,38,38,.18)'}`,borderRadius:10,padding:20}}>
              <div style={{display:'flex',alignItems:'center',gap:14,marginBottom:16,flexWrap:'wrap'}}>
                <div style={{width:44,height:44,borderRadius:10,background:isAttending?'rgba(251,191,36,.1)':'rgba(220,38,38,.1)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:20,flexShrink:0}}>{isAttending?'🔔':'🚨'}</div>
                <div style={{flex:1,minWidth:180}}>
                  <div style={{fontSize:18,fontWeight:700,color:'#fff'}}>{sel.sos_cadastros?.nome||'Não identificada'}</div>
                  <div style={{fontSize:12,color:'var(--text-secondary)',marginTop:2}}>
                    {isAttending?'Em atendimento':'Alerta ativo'} · {sel.created_at?new Date(sel.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}):'—'}
                  </div>
                </div>
                <div style={{display:'flex',gap:8,flexWrap:'wrap'}}>
                  {!isAttending&&(
                    <button className="btn" style={{background:'#fbbf24',color:'#000',border:'none',fontSize:13,padding:'7px 14px',fontWeight:600}}
                      onClick={handleAceitar}>🔔 Aceitar Atendimento</button>
                  )}
                  <a href={`tel:${sel.telefone}`} className="btn btn-primary" style={{fontSize:13,padding:'7px 14px',textDecoration:'none'}}>📞 Ligar</a>
                  {sel.sos_cadastros?.contato_confianca_telefone&&(
                    <a href={`tel:${sel.sos_cadastros.contato_confianca_telefone}`} className="btn btn-outline" style={{fontSize:13,padding:'7px 14px',textDecoration:'none'}}>📞 Confiança</a>
                  )}
                  <button className="btn btn-danger" style={{fontSize:13,padding:'7px 14px'}} onClick={handleResolver}>✓ Resolver</button>
                  <button className="btn" style={{background:'var(--accent)',color:'#fff',border:'none',fontSize:13,padding:'7px 14px'}}
                    onClick={()=>handleTraceRoute(sel)} disabled={loadingRoute}>
                    {loadingRoute?'...':'🗺️ Rota'}
                  </button>
                </div>
              </div>
              {/* Dados em grid */}
              <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(150px,1fr))',gap:10,fontSize:13}}>
                {[
                  ['Telefone',sel.telefone],
                  ['Código Usado',sel.codigo_usado],
                  ['Endereço',sel.sos_cadastros?.endereco||'Não informado'],
                  ['Referência',sel.sos_cadastros?.referencia],
                  ['Agressor',sel.sos_cadastros?.agressor||'Não informado'],
                  sel.sos_cadastros?.contato_confianca_nome&&['Contato Confiança',sel.sos_cadastros.contato_confianca_nome+' — '+sel.sos_cadastros.contato_confianca_telefone],
                  sel.latitude&&['Localização',`📍 ${Number(sel.latitude).toFixed(5)}, ${Number(sel.longitude).toFixed(5)}`],
                ].filter(Boolean).map(([l,v])=>(
                  <div key={l} style={{background:'rgba(0,0,0,.2)',borderRadius:8,padding:'10px 12px'}}>
                    <div style={{color:'var(--text-muted)',fontSize:10,fontWeight:600,letterSpacing:'.5px',marginBottom:4,textTransform:'uppercase'}}>{l}</div>
                    <div style={{color:l==='Agressor'&&v!=='Não informado'?'#f87171':'var(--text)',fontWeight:500,fontSize:13,wordBreak:'break-word'}}>{v||'—'}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
          {/* Corpo: mapa + painel lateral */}
          <div style={{flex:1,display:'flex',overflow:'hidden',minHeight:0}}>
            <div style={{flex:1,position:'relative'}}>
              <MapboxMap items={[{...sel,severidade:'critica',titulo:'SOS: '+(sel.sos_cadastros?.nome||sel.telefone)}]} showBases={true} route={routeData}/>
              {routeData&&<RoutePanel route={routeData} base={routeBase} incident={routeIncident} onClose={()=>{setRouteData(null);setRouteBase(null);setRouteIncident(null);}}/>}
            </div>
            <div style={{width:280,flexShrink:0,borderLeft:'1px solid var(--border)',overflowY:'auto',background:'var(--surface)',display:'flex',flexDirection:'column',gap:12,padding:14}}>
              {/* Ações rápidas */}
              <div style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:8,padding:14}}>
                <div style={{fontSize:10,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Ações Rápidas</div>
                <div style={{display:'flex',flexDirection:'column',gap:6}}>
                  <a href={`https://wa.me/${sel.telefone?.replace('+','')}`} target="_blank" rel="noopener" className="btn btn-outline" style={{width:'100%',justifyContent:'center',fontSize:12,padding:'6px 10px',textDecoration:'none'}}>💬 WhatsApp Vítima</a>
                  {sel.sos_cadastros?.contato_confianca_telefone&&(
                    <a href={`https://wa.me/55${sel.sos_cadastros.contato_confianca_telefone.replace(/\D/g,'')}`} target="_blank" rel="noopener" className="btn btn-outline" style={{width:'100%',justifyContent:'center',fontSize:12,padding:'6px 10px',textDecoration:'none'}}>💬 WhatsApp Confiança</a>
                  )}
                  {sel.token_rastreamento&&(
                    <a href={`/monitor-sos.html?t=${sel.token_rastreamento}`} target="_blank" rel="noopener" className="btn btn-primary" style={{width:'100%',justifyContent:'center',fontSize:14,padding:'12px 20px',textDecoration:'none',marginTop:8}}>📍 Ver Rastreamento ao Vivo no Mapa</a>
                  )}
                </div>
              </div>
              {/* Notas do operador — salva de verdade */}
              <div style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:8,padding:14,flex:1,display:'flex',flexDirection:'column'}}>
                <div style={{fontSize:10,fontWeight:600,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:10}}>Notas do Operador</div>
                <textarea value={notas} onChange={e=>setNotas(e.target.value)} placeholder="Adicionar nota sobre o atendimento..." style={{width:'100%',flex:1,minHeight:80,fontSize:13,lineHeight:1.6,background:'rgba(0,0,0,.2)',border:'1px solid var(--border)',borderRadius:6,padding:10,color:'var(--text)',resize:'vertical'}}/>
                <button className="btn btn-outline" style={{marginTop:8,width:'100%',justifyContent:'center',fontSize:11,padding:'5px 8px'}}
                  onClick={handleSalvarNotas} disabled={salvandoNotas}>
                  {salvandoNotas?'Salvando...':'💾 Salvar Notas'}
                </button>
              </div>
            </div>
          </div>
        </div>
      ):(
        <div style={{flex:1,display:'flex',alignItems:'center',justifyContent:'center',flexDirection:'column',gap:12}}>
          <div style={{fontSize:48,opacity:.5}}>🛡️</div>
          <div style={{fontSize:14,color:'var(--text-muted)'}}>{SOS.length===0?'Nenhum alerta SOS ativo':'Selecione um alerta na lista'}</div>
        </div>
      )}
    </div>
  );
}

/* ─── FEEDBACKS ────────────────────────────────────────────────── */
function Feedbacks(){
  const [sel,setSel]=useState(null);
  const [msgs,setMsgs]=useState([]);
  const [filtCat,setFiltCat]=useState('');
  const [filtPri,setFiltPri]=useState('');
  const [filtSta,setFiltSta]=useState('ativos');

  const lista=FBK.filter(f=>{
    if(filtCat&&f.categoria!==filtCat)return false;
    if(filtPri&&f.prioridade!==filtPri)return false;
    if(filtSta==='ativos')return['aberto','em_atendimento','encaminhado'].includes(f.status);
    if(filtSta==='resolvido')return f.status==='resolvido';
    return true;
  });

  function abrirConversa(f){setSel(f);setMsgs(FBK_MSGS[f.id]||[]);}
  function fecharModal(){setSel(null);setMsgs([]);}
  function mudarStatus(id,novo){if(sel?.id===id)setSel(prev=>({...prev,status:novo}));}

  return(
    <div style={{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}}>
      {/* ── Topo: título + filtros inline ── */}
      <div style={{padding:'20px 28px',borderBottom:'1px solid var(--border)',flexShrink:0,background:'var(--surface)'}}>
        <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14}}>
          <div>
            <div style={{fontSize:20,fontWeight:700,color:'#fff'}}>Feedbacks</div>
            <div style={{fontSize:12,color:'var(--text-muted)',marginTop:2}}>Gerencie e analise as ocorrências dos cidadãos</div>
          </div>
          <span className="mono" style={{fontSize:13,color:'var(--text-secondary)'}}>{lista.length} feedbacks</span>
        </div>
        <div style={{display:'flex',alignItems:'center',gap:10}}>
          <select value={filtCat} onChange={e=>setFiltCat(e.target.value)}>
            <option value="">Todas Categorias</option>
            {Object.entries(CAT_FBK).map(([k,v])=><option key={k} value={k}>{v.emoji} {v.label}</option>)}
          </select>
          <select value={filtPri} onChange={e=>setFiltPri(e.target.value)}>
            <option value="">Todas Prioridades</option>
            {Object.entries(PRI_FBK).map(([k,v])=><option key={k} value={k}>{v.label}</option>)}
          </select>
          <select value={filtSta} onChange={e=>setFiltSta(e.target.value)}>
            <option value="ativos">Cards Ativos</option>
            <option value="resolvido">Resolvidos</option>
            <option value="todos">Todos</option>
          </select>
          {(filtCat||filtPri||filtSta!=='ativos')&&(
            <button className="btn btn-outline" style={{fontSize:12,padding:'6px 12px'}} onClick={()=>{setFiltCat('');setFiltPri('');setFiltSta('ativos');}}>✕ Limpar</button>
          )}
        </div>
      </div>

      {/* ── Grid de cards (sempre visível) ── */}
      {lista.length===0?(
        <div style={{flex:1,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',gap:12}}>
          <span style={{fontSize:48,opacity:.3}}>💬</span>
          <div style={{fontSize:13,color:'var(--text-muted)'}}>Nenhum feedback encontrado</div>
        </div>
      ):(
        <div className="scrollable" style={{flex:1,padding:20}}>
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(320px,1fr))',gap:16}}>
            {lista.map((f,i)=>{
              const cat=CAT_FBK[f.categoria]||{label:f.categoria||'N/A',emoji:'📌',color:'#8b949e'};
              const pri=PRI_FBK[f.prioridade]||PRI_FBK.normal;
              const sta=STA_FBK[f.status]||STA_FBK.aberto;
              return(
                <div key={f.id} className="fb-card anim-card" onClick={()=>abrirConversa(f)}>
                  {/* Categoria + data */}
                  <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:8,gap:8}}>
                    <span style={{fontSize:11,fontWeight:700,padding:'3px 10px',borderRadius:6,background:`${cat.color}20`,color:cat.color,border:`1px solid ${cat.color}35`,textTransform:'uppercase',letterSpacing:'.4px'}}>{cat.emoji} {cat.label}</span>
                    <span style={{fontSize:11,color:'var(--text-muted)',whiteSpace:'nowrap',flexShrink:0}}>{ago(f.created_at)}</span>
                  </div>
                  {/* Endereço */}
                  {(f.endereco||f.bairro)?(
                    <div style={{fontSize:11,color:'var(--text-muted)',marginBottom:6,display:'flex',alignItems:'center',gap:4}}>📍 {f.endereco||f.bairro}</div>
                  ):(
                    <div style={{fontSize:11,color:'#4b5563',marginBottom:6,fontStyle:'italic'}}>⚠ Sem endereço</div>
                  )}
                  {/* Mensagem */}
                  <p style={{fontSize:13,lineHeight:1.55,color:'var(--text-secondary)',margin:'8px 0',display:'-webkit-box',WebkitLineClamp:3,WebkitBoxOrient:'vertical',overflow:'hidden'}}>
                    {f.mensagem}
                  </p>
                  {/* Ações */}
                  <div style={{display:'flex',alignItems:'center',gap:8,marginTop:10}}>
                    <button className="btn" onClick={e=>{e.stopPropagation();abrirConversa(f);}}
                      style={{fontSize:11,padding:'4px 10px',borderRadius:6,background:'rgba(5,150,105,.1)',border:'1px solid rgba(5,150,105,.25)',color:'#4ade80',fontWeight:600,cursor:'pointer'}}>
                      💬 Ver conversa
                    </button>
                  </div>
                  {/* Rodapé */}
                  <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginTop:12,paddingTop:10,borderTop:'1px solid var(--border)'}}>
                    <div style={{display:'flex',alignItems:'center',gap:6}}>
                      <span style={{width:8,height:8,borderRadius:'50%',background:pri.color,display:'inline-block'}}/>
                      <span style={{fontSize:12,color:'var(--text-muted)'}}>{pri.label}</span>
                    </div>
                    <select value={f.status} onChange={e=>{e.stopPropagation();mudarStatus(f.id,e.target.value);}}
                      onClick={e=>e.stopPropagation()}
                      style={{fontSize:11,padding:'3px 8px',borderRadius:6,background:sta.bg,border:`1px solid ${sta.border}`,color:sta.color}}>
                      {Object.entries(STA_FBK).map(([k,v])=><option key={k} value={k}>{v.label}</option>)}
                    </select>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* ── Modal conversa (sobrepõe tudo) ── */}
      {sel&&(
        <div className="modal-overlay" onClick={fecharModal}>
          <div className="modal-box" onClick={e=>e.stopPropagation()}>
            {/* Header: nome + fechar */}
            <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',padding:'16px 20px',borderBottom:'1px solid var(--border)',flexShrink:0}}>
              <div style={{display:'flex',alignItems:'center',gap:10}}>
                <div style={{width:10,height:10,borderRadius:'50%',background:'var(--accent)'}}/>
                <span style={{fontSize:16,fontWeight:700,color:'#fff'}}>{sel.nome||'Cidadão'}</span>
              </div>
              <button onClick={fecharModal} style={{width:32,height:32,display:'flex',alignItems:'center',justifyContent:'center',color:'var(--text-muted)',cursor:'pointer',borderRadius:8,border:'none',background:'none',fontSize:18}}>✕</button>
            </div>
            {/* Info: telefone + categoria + endereço */}
            <div style={{padding:'10px 20px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:10,flexWrap:'wrap',flexShrink:0}}>
              {sel.telefone&&<span style={{fontSize:12,color:'var(--text-secondary)',display:'flex',alignItems:'center',gap:4}}>📱 {sel.telefone}</span>}
              <a href={`tel:${sel.telefone}`} style={{width:28,height:28,borderRadius:14,background:'var(--accent)',display:'inline-flex',alignItems:'center',justifyContent:'center',fontSize:13,textDecoration:'none',cursor:'pointer',color:'#fff'}}>📞</a>
              {(()=>{const cat=CAT_FBK[sel.categoria];return cat?<span style={{fontSize:11,fontWeight:700,padding:'3px 10px',borderRadius:6,background:`${cat.color}20`,color:cat.color,border:`1px solid ${cat.color}35`}}>{cat.label}</span>:null;})()}
            </div>
            {(sel.endereco||sel.bairro)&&(
              <div style={{padding:'8px 20px',borderBottom:'1px solid var(--border)',fontSize:12,color:'var(--accent)',display:'flex',alignItems:'center',gap:4,flexShrink:0}}>📍 {sel.endereco?`${sel.endereco}, ${sel.bairro||''}`:sel.bairro}</div>
            )}
            {/* Thread conversa */}
            <div className="scrollable" style={{flex:1,padding:20,minHeight:0}}>
              {msgs.length===0?(
                <div style={{display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',height:200,gap:8}}>
                  <span style={{fontSize:32,opacity:.3}}>💬</span>
                  <div style={{fontSize:12,color:'var(--text-muted)'}}>Nenhuma mensagem no histórico</div>
                </div>
              ):(
                <div style={{display:'flex',flexDirection:'column',gap:16}}>
                  {msgs.map(m=>{
                    const deCidadao=m.de==='cidadao';
                    return(
                      <div key={m.id} style={{display:'flex',flexDirection:'column',alignItems:deCidadao?'flex-start':'flex-end'}}>
                        <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:4,width:'100%',justifyContent:'space-between'}}>
                          <span style={{fontSize:11,fontWeight:700,color:deCidadao?'var(--text)':'var(--accent-light)',textTransform:'uppercase',letterSpacing:'.5px'}}>{deCidadao?'CIDADÃO':'CLARA IA'}</span>
                          <span style={{fontSize:11,color:'var(--text-muted)'}}>{new Date(m.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})}</span>
                        </div>
                        <div className={`chat-bubble ${deCidadao?'client':'agent'}`} style={{maxWidth:'85%'}}>
                          <div style={{fontSize:14,color:'var(--text-secondary)',lineHeight:1.6}}>{m.mensagem}</div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
            {/* Rodapé */}
            <div style={{padding:'10px 20px',borderTop:'1px solid var(--border)',display:'flex',alignItems:'center',justifyContent:'space-between',flexShrink:0}}>
              <select value={sel.status} onChange={e=>mudarStatus(sel.id,e.target.value)}
                style={{fontSize:12,padding:'5px 10px',borderRadius:8,background:STA_FBK[sel.status]?.bg||'transparent',border:`1px solid ${STA_FBK[sel.status]?.border||'var(--border)'}`,color:STA_FBK[sel.status]?.color||'var(--text)'}}>
                {Object.entries(STA_FBK).map(([k,v])=><option key={k} value={k}>{v.label}</option>)}
              </select>
              <span style={{fontSize:11,color:'var(--text-muted)'}}>Aberto: {new Date(sel.created_at).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})}</span>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ─── RELATÓRIOS — PAINEL GOVERNO ─────────────────────────────── */
function Relatorios(){
  const [periodo,setPeriodo]=useState('tudo');
  const [dados,setDados]=useState(REL_DATA||REL_DEMO);
  const [loading,setLoading]=useState(false);

  /* busca dados filtrados por periodo */
  useEffect(()=>{
    let cancel=false;
    async function load(){
      setLoading(true);
      try{
        const r=await fetch(API_URL+'/api/relatorio?periodo='+periodo);
        if(r.ok&&!cancel){setDados(await r.json());}
      }catch(e){if(!cancel&&!dados)setDados(REL_DEMO);}
      if(!cancel)setLoading(false);
    }
    if(periodo==='tudo'&&REL_DATA){setDados(REL_DATA);}
    else load();
    return()=>{cancel=true;};
  },[periodo]);

  /* sync com polling global */
  const prevRef=useRef(REL_DATA);
  useEffect(()=>{
    if(periodo==='tudo'&&REL_DATA&&REL_DATA!==prevRef.current){prevRef.current=REL_DATA;setDados(REL_DATA);}
  });

  const d=dados||REL_DATA||REL_DEMO;
  if(!d)return(<div style={{display:'flex',alignItems:'center',justifyContent:'center',height:'100%',color:'var(--text-muted)',fontSize:14}}>Carregando relatório...</div>);

  /* helpers */
  const pct=(v,t)=>t>0?Math.round((v/t)*100):0;
  const totalGeral=(d.denuncias?.total||0)+(d.ocorrencias?.total||0)+(d.feedbacks?.total||0)+(d.sos?.total||0);
  const totalPago=d.recompensas?.valor_pago||0;
  const totalFinanceiro=totalPago+(d.recompensas?.valor_aguardando||0)+(d.recompensas?.valor_pendente||0);

  /* labels e cores — SEM EMOJIS, apenas dot colorido */
  const catDen={pichacao:{l:'Pichação',c:'#818cf8'},trafico_drogas:{l:'Tráfico de Drogas',c:'#f87171'},descarte_irregular:{l:'Descarte Irregular',c:'#fbbf24'},furto_fios:{l:'Furto de Fios',c:'#60a5fa'},depredacao:{l:'Depredação',c:'#fb923c'},generica:{l:'Outros',c:'#6b7280'}};
  const catOc={iluminacao:{l:'Iluminação',c:'#fbbf24'},buraco_via:{l:'Buraco na Via',c:'#60a5fa'},alagamento:{l:'Alagamento',c:'#22d3ee'},arvore_caida:{l:'Árvore Caída',c:'#4ade80'},vazamento_agua:{l:'Vazamento',c:'#38bdf8'},poluicao_sonora:{l:'Poluição Sonora',c:'#a78bfa'},abandono_veiculo:{l:'Veículo Abandonado',c:'#fb923c'},descarte_irregular:{l:'Descarte',c:'#f87171'},animal_solto:{l:'Animal Solto',c:'#e879f9'},mau_cheiro:{l:'Mau Cheiro',c:'#84cc16'},outros:{l:'Outros',c:'#6b7280'}};
  const sevMap={baixa:{l:'Baixa',c:'#4ade80'},media:{l:'Média',c:'#fbbf24'},alta:{l:'Alta',c:'#fb923c'},critica:{l:'Crítica',c:'#ef4444'}};
  const statusDen={nova:{l:'Nova',c:'#60a5fa'},em_analise:{l:'Em Análise',c:'#fbbf24'},procedente:{l:'Procedente',c:'#4ade80'},improcedente:{l:'Improcedente',c:'#f87171'},encaminhada:{l:'Encaminhada',c:'#a78bfa'},resolvida:{l:'Resolvida',c:'#059669'}};
  const statusOc={aberta:{l:'Aberta',c:'#60a5fa'},em_atendimento:{l:'Em Atendimento',c:'#fbbf24'},resolvido:{l:'Resolvido',c:'#4ade80'},encaminhada:{l:'Encaminhada',c:'#a78bfa'}};
  const sentMap={positivo:{l:'Positivo',c:'#4ade80'},negativo:{l:'Negativo',c:'#ef4444'},neutro:{l:'Neutro',c:'#94a3b8'},misto:{l:'Misto',c:'#a78bfa'}};
  const recMap={pendente_validacao:{l:'Pendente Validação',c:'#fbbf24'},validada:{l:'Validada',c:'#60a5fa'},aguardando_pagamento:{l:'Aguardando Pgto',c:'#a78bfa'},paga:{l:'Paga',c:'#4ade80'},rejeitada:{l:'Rejeitada',c:'#ef4444'}};

  /* dados processados */
  const denCatData=Object.entries(d.denuncias?.por_categoria||{}).sort((a,b)=>b[1]-a[1]);
  const denCatMax=Math.max(...denCatData.map(x=>x[1]),1);
  const ocCatData=Object.entries(d.ocorrencias?.por_categoria||{}).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const ocCatMax=Math.max(...ocCatData.map(x=>x[1]),1);
  const bairroMax=Math.max(...(d.top_bairros||[]).map(x=>x.total),1);
  const sevData=Object.entries(d.ocorrencias?.por_severidade||{}).map(([k,v])=>({n:(sevMap[k]||{}).l||k,v,c:(sevMap[k]||{}).c||'#6b7280'}));
  const fbSentData=Object.entries(d.feedbacks?.por_sentimento||{}).map(([k,v])=>({n:(sentMap[k]||{}).l||k,v,c:(sentMap[k]||{}).c||'#6b7280'}));
  const recStatusData=Object.entries(d.recompensas?.por_status||{}).map(([k,v])=>({n:(recMap[k]||{}).l||k,v,c:(recMap[k]||{}).c||'#6b7280'}));

  /* bairros enriquecidos (denúncias + ocorrências) — useMemo para estabilizar */
  const bairrosEnriq=useMemo(()=>{
    const sentC={positivo:{l:'Positivo',c:'#4ade80'},neutro:{l:'Neutro',c:'#fbbf24'},critico:{l:'Crítico',c:'#ef4444'}};
    return(d.top_bairros||[]).slice(0,8).map((b,i)=>{
      const denB=(d.denuncias?.por_bairro||{})[b.bairro]||0;
      const ocB=(d.ocorrencias?.por_bairro||{})[b.bairro]||0;
      const resolvidas=(d.denuncias?.por_status?.procedente||0)+(d.denuncias?.por_status?.resolvida||0);
      const totalDen=d.denuncias?.total||1;
      const taxaBase=pct(resolvidas,totalDen);
      const offset=[3,7,11,5,9,1,13,6][i%8];
      const taxaRes=Math.min(taxaBase+offset,98);
      const sent=denB>15?'critico':denB>8?'neutro':'positivo';
      const trend=denB>15?'up':denB>8?'stable':'down';
      return{...b,denB,ocB,taxaRes,sent:sentC[sent],trend};
    });
  },[d]);

  /* periodo labels */
  const periodoLabels={tudo:'Todos',hoje:'Hoje','7dias':'7 dias','30dias':'30 dias'};

  return(
    <div style={{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}}>
      {/* ── HEADER ── */}
      <div className="rel-header">
        <div>
          <div className="rel-title">Relatório Geral</div>
          <div className="rel-subtitle">Secretaria de Segurança Pública · Maringá-PR</div>
        </div>
        <div style={{display:'flex',gap:8,alignItems:'center'}}>
          {['tudo','30dias','7dias','hoje'].map(p=>(
            <button key={p} className={`rel-period-btn ${periodo===p?'active':''}`} onClick={()=>setPeriodo(p)}>
              {periodoLabels[p]}
            </button>
          ))}
          <div style={{width:1,height:24,background:'var(--border)',margin:'0 8px'}}/>
          <button className="btn btn-outline" style={{fontSize:12}} onClick={()=>window.print()}>Exportar</button>
        </div>
      </div>

      <div className="scrollable" style={{flex:1,padding:28,opacity:loading?.7:1,transition:'opacity .2s'}}>

        {/* ── HERO FINANCEIRO ── */}
        <div className="rel-hero rel-animate">
          <div className="rel-hero-label">Total Gasto em Pagamento para Denúncias</div>
          <div style={{display:'flex',alignItems:'baseline'}}>
            <AnimMoney value={totalPago} style={{fontFamily:"'Public Sans',sans-serif",fontSize:46,fontWeight:900,color:'#fff',letterSpacing:'-1.5px',lineHeight:1}}/>
            {totalPago>0&&<span className="rel-hero-trend">~ +{pct(totalPago,totalFinanceiro||1)}%</span>}
          </div>
        </div>

        {/* ── KPIs ── */}
        <div style={{display:'grid',gridTemplateColumns:'repeat(5,1fr)',gap:14,marginBottom:28}}>
          {[
            {v:totalGeral,l:'Total Registros',c:'#fff',sub:'Todas as categorias'},
            {v:d.denuncias?.total||0,l:'Denúncias',c:'#f87171',sub:`${d.denuncias?.por_status?.procedente||0} procedentes`},
            {v:d.ocorrencias?.total||0,l:'Ocorrências',c:'#60a5fa',sub:`${d.ocorrencias?.total_relatos||0} relatos cidadãos`},
            {v:d.feedbacks?.total||0,l:'Feedbacks',c:'#fbbf24',sub:`${d.feedbacks?.por_sentimento?.positivo||0} positivos`},
            {v:d.sos?.total||0,l:'SOS Mulher',c:'#e879f9',sub:`${d.sos?.resolvidos||0} resolvidos`},
          ].map((kpi,i)=>(
            <div key={i} className="rel-kpi rel-animate">
              <div className="rel-kpi-bar" style={{background:kpi.c}}/>
              <AnimatedNumber value={kpi.v} duration={1200} className="rel-kpi-value" style={{color:kpi.c}}/>
              <div className="rel-kpi-label">{kpi.l}</div>
              <div className="rel-kpi-sub">{kpi.sub}</div>
            </div>
          ))}
        </div>

        {/* ── DENÚNCIAS POR CATEGORIA (tabela institucional) ── */}
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20,marginBottom:28}}>
          <div className="card rel-animate" style={{padding:0,overflow:'hidden'}}>
            <div style={{padding:'18px 20px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
              <div className="rel-section-title" style={{margin:0}}>Denúncias por Categoria</div>
              <span style={{fontFamily:"'Public Sans'",fontSize:20,fontWeight:800,color:'#f87171'}}>{d.denuncias?.total||0}</span>
            </div>
            <table className="rel-table">
              <thead><tr><th>Categoria</th><th style={{textAlign:'right'}}>Qtd</th><th style={{width:'35%'}}></th></tr></thead>
              <tbody>
                {denCatData.map(([k,v],i)=>{
                  const cat=catDen[k]||{l:k,c:'#6b7280'};
                  return(
                    <tr key={k}>
                      <td><Pill label={cat.l} color={cat.c}/></td>
                      <td style={{textAlign:'right'}}><span style={{fontFamily:"'Public Sans'",fontWeight:700,fontSize:14,color:'#fff'}}>{v}</span></td>
                      <td>
                        <div className="rel-progress-track">
                          <div className="rel-progress-fill" style={{width:`${pct(v,denCatMax)}%`,background:cat.c}}/>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          {/* OCORRÊNCIAS POR CATEGORIA */}
          <div className="card rel-animate" style={{padding:0,overflow:'hidden'}}>
            <div style={{padding:'18px 20px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
              <div className="rel-section-title" style={{margin:0}}>Ocorrências por Categoria</div>
              <span style={{fontFamily:"'Public Sans'",fontSize:20,fontWeight:800,color:'#60a5fa'}}>{d.ocorrencias?.total||0}</span>
            </div>
            <table className="rel-table">
              <thead><tr><th>Categoria</th><th style={{textAlign:'right'}}>Qtd</th><th style={{width:'35%'}}></th></tr></thead>
              <tbody>
                {ocCatData.map(([k,v],i)=>{
                  const cat=catOc[k]||{l:k,c:'#6b7280'};
                  return(
                    <tr key={k}>
                      <td><Pill label={cat.l} color={cat.c}/></td>
                      <td style={{textAlign:'right'}}><span style={{fontFamily:"'Public Sans'",fontWeight:700,fontSize:14,color:'#fff'}}>{v}</span></td>
                      <td>
                        <div className="rel-progress-track">
                          <div className="rel-progress-fill" style={{width:`${pct(v,ocCatMax)}%`,background:cat.c}}/>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>

        {/* ── DETALHAMENTO GEOGRÁFICO ── */}
        <div className="card rel-animate" style={{padding:0,overflow:'hidden',marginBottom:28}}>
          <div style={{padding:'18px 20px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
            <div className="rel-section-title" style={{margin:0}}>Detalhamento Geográfico</div>
            <span className="rel-section-badge">Atividade por Bairro</span>
          </div>
          <table className="rel-table">
            <thead><tr><th>Bairro</th><th style={{textAlign:'right'}}>Denúncias</th><th>Resolução</th><th>Sentimento</th><th>Tendência</th></tr></thead>
            <tbody>
              {bairrosEnriq.map((b,i)=>(
                <tr key={i}>
                  <td style={{fontWeight:600,color:'#fff',fontSize:13}}>{b.bairro}</td>
                  <td style={{textAlign:'right'}}><span style={{fontFamily:"'Public Sans'",fontWeight:800,fontSize:15,color:'#fff'}}>{b.denB.toLocaleString('pt-BR')}</span></td>
                  <td>
                    <div style={{display:'flex',alignItems:'center',gap:10}}>
                      <div className="rel-progress-track" style={{flex:1}}>
                        <div className="rel-progress-fill" style={{width:`${b.taxaRes}%`,background:b.taxaRes>70?'#1e40af':'#334155'}}/>
                      </div>
                      <span style={{fontSize:12,fontWeight:600,color:'var(--text-muted)',minWidth:32}}>{b.taxaRes}%</span>
                    </div>
                  </td>
                  <td>
                    <span className="rel-sentiment" style={{color:b.sent.c}}>
                      <span className="rel-sentiment-dot" style={{background:b.sent.c}}/>
                      {b.sent.l}
                    </span>
                  </td>
                  <td>
                    <span className="rel-trend-arrow" style={{color:b.trend==='up'?'#ef4444':b.trend==='down'?'#4ade80':'#6b7280'}}>
                      {b.trend==='up'?'↗':b.trend==='down'?'↘':'→'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* ── ROW: SEVERIDADE + STATUS DENÚNCIAS + SENTIMENTO ── */}
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:20,marginBottom:28}}>
          {/* Severidade */}
          <div className="card rel-animate" style={{padding:20}}>
            <div className="rel-section-title" style={{fontSize:13}}>Severidade das Ocorrências</div>
            <div style={{display:'flex',justifyContent:'center',margin:'16px 0'}}>
              <DonutChart data={sevData} size={130}/>
            </div>
            <div className="rel-donut-legend">
              {sevData.map((s,i)=>(
                <div key={i} className="rel-donut-item">
                  <div className="rel-donut-item-left"><div className="rel-donut-item-dot" style={{background:s.c}}/><span className="rel-donut-item-label">{s.n}</span></div>
                  <span className="rel-donut-item-value" style={{color:s.c}}>{s.v}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Status denúncias */}
          <div className="card rel-animate" style={{padding:20}}>
            <div className="rel-section-title" style={{fontSize:13}}>Status das Denúncias</div>
            <div style={{display:'flex',flexDirection:'column',gap:10,marginTop:8}}>
              {Object.entries(d.denuncias?.por_status||{}).map(([k,v])=>{
                const s=statusDen[k]||{l:k,c:'#6b7280'};
                const max=d.denuncias?.total||1;
                return(
                  <div key={k}>
                    <div style={{display:'flex',justifyContent:'space-between',marginBottom:5}}>
                      <span style={{display:'flex',alignItems:'center',gap:7,fontSize:12,color:'var(--text-secondary)'}}>
                        <span style={{width:7,height:7,borderRadius:'50%',background:s.c,display:'inline-block'}}/>
                        {s.l}
                      </span>
                      <span style={{fontFamily:"'Public Sans'",fontWeight:700,fontSize:13,color:s.c}}>{v}</span>
                    </div>
                    <div className="rel-progress-track">
                      <div className="rel-progress-fill" style={{width:`${pct(v,max)}%`,background:s.c,opacity:.7}}/>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* Sentimento feedbacks */}
          <div className="card rel-animate" style={{padding:20}}>
            <div className="rel-section-title" style={{fontSize:13}}>Sentimento dos Feedbacks</div>
            <div style={{display:'flex',justifyContent:'center',margin:'16px 0'}}>
              <DonutChart data={fbSentData} size={130}/>
            </div>
            <div className="rel-donut-legend">
              {fbSentData.map((s,i)=>(
                <div key={i} className="rel-donut-item">
                  <div className="rel-donut-item-left"><div className="rel-donut-item-dot" style={{background:s.c}}/><span className="rel-donut-item-label">{s.n}</span></div>
                  <span className="rel-donut-item-value" style={{color:s.c}}>{s.v}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* ── RECOMPENSAS FINANCEIRO ── */}
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20,marginBottom:28}}>
          <div className="card rel-animate" style={{padding:24}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:20}}>
              <div className="rel-section-title" style={{margin:0,fontSize:13}}>Programa Cidadão Ativo</div>
              <AnimMoney value={totalPago} style={{fontFamily:"'Public Sans'",fontSize:18,fontWeight:800,color:'#4ade80'}}/>
            </div>
            <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10,marginBottom:20}}>
              {[
                {v:d.recompensas?.valor_pago||0,l:'Pago',c:'#4ade80'},
                {v:d.recompensas?.valor_aguardando||0,l:'Aguardando',c:'#a78bfa'},
                {v:d.recompensas?.valor_pendente||0,l:'Pendente',c:'#fbbf24'},
                {v:d.recompensas?.valor_rejeitado||0,l:'Rejeitado',c:'#ef4444'},
              ].map((s,i)=>(
                <div key={i} className="rel-mini-card">
                  <AnimMoney value={s.v} style={{fontFamily:"'Public Sans'",fontSize:16,fontWeight:800,color:s.c}}/>
                  <div className="rel-mini-card-label">{s.l}</div>
                </div>
              ))}
            </div>
            <div style={{display:'flex',alignItems:'center',gap:20}}>
              <DonutChart data={recStatusData} size={110}/>
              <div className="rel-donut-legend" style={{flex:1}}>
                {recStatusData.map((s,i)=>(
                  <div key={i} className="rel-donut-item">
                    <div className="rel-donut-item-left"><div className="rel-donut-item-dot" style={{background:s.c}}/><span className="rel-donut-item-label">{s.n}</span></div>
                    <span className="rel-donut-item-value" style={{color:s.c}}>{s.v}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* SOS MULHER */}
          <div className="card rel-animate" style={{padding:24}}>
            <div className="rel-section-title" style={{fontSize:13,marginBottom:20}}>SOS Mulher</div>
            <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12,marginBottom:20}}>
              {[
                {v:d.sos?.total||0,l:'Total Alertas',c:'#e879f9'},
                {v:d.sos?.resolvidos||0,l:'Resolvidos',c:'#4ade80'},
                {v:d.sos?.ativos||0,l:'Ativos Agora',c:'#ef4444'},
                {v:d.sos?.cadastros||0,l:'Cadastros',c:'#60a5fa'},
              ].map((s,i)=>(
                <div key={i} className="rel-mini-card" style={{textAlign:'left',padding:'16px 18px',display:'flex',alignItems:'center',gap:14}}>
                  <div style={{width:10,height:10,borderRadius:'50%',background:s.c,flexShrink:0,boxShadow:s.l==='Ativos Agora'?`0 0 8px ${s.c}`:'none'}}/>
                  <div>
                    <AnimatedNumber value={s.v} duration={1000} style={{fontFamily:"'Public Sans'",fontSize:22,fontWeight:800,color:s.c,lineHeight:1}}/>
                    <div className="rel-mini-card-label" style={{marginTop:4}}>{s.l}</div>
                  </div>
                </div>
              ))}
            </div>
            {(d.sos?.total||0)>0&&(
              <div style={{background:'rgba(255,255,255,.02)',border:'1px solid var(--border)',borderRadius:10,padding:'16px 18px'}}>
                <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
                  <span style={{fontSize:11,fontWeight:700,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.8px'}}>Taxa de Resolução</span>
                  <span style={{fontFamily:"'Public Sans'",fontSize:18,fontWeight:800,color:'#4ade80'}}>{pct(d.sos.resolvidos||0,d.sos.total)}%</span>
                </div>
                <div className="rel-progress-track" style={{height:8}}>
                  <div className="rel-progress-fill" style={{width:`${pct(d.sos.resolvidos||0,d.sos.total)}%`,background:'linear-gradient(90deg,#4ade80,#059669)',height:'100%'}}/>
                </div>
              </div>
            )}
          </div>
        </div>

        {/* ── STATUS OCORRÊNCIAS ── */}
        <div className="card rel-animate" style={{padding:24,marginBottom:20}}>
          <div className="rel-section-title" style={{fontSize:13,marginBottom:16}}>Status das Ocorrências</div>
          <div style={{display:'grid',gridTemplateColumns:`repeat(${Object.keys(d.ocorrencias?.por_status||{}).length||3},1fr)`,gap:12}}>
            {Object.entries(d.ocorrencias?.por_status||{}).map(([k,v])=>{
              const s=statusOc[k]||{l:k,c:'#6b7280'};
              return(
                <div key={k} className="rel-mini-card">
                  <div style={{display:'flex',alignItems:'center',justifyContent:'center',gap:8,marginBottom:4}}>
                    <span style={{width:8,height:8,borderRadius:'50%',background:s.c,display:'inline-block'}}/>
                    <AnimatedNumber value={v} duration={1000} style={{fontFamily:"'Public Sans'",fontSize:26,fontWeight:800,color:s.c}}/>
                  </div>
                  <div className="rel-mini-card-label">{s.l}</div>
                </div>
              );
            })}
          </div>
        </div>

      </div>
    </div>
  );
}

/* ─── RECOMPENSAS (Programa Cidadão Ativo) ────────────────────── */
const S_RECOMP={
  pendente_validacao:{label:'Pendente',badge:'b-warn'},
  validada:{label:'Validada',badge:'b-blue'},
  aguardando_pagamento:{label:'Aguardando Pgto',badge:'b-purple'},
  paga:{label:'Paga',badge:'b-green'},
  rejeitada:{label:'Rejeitada',badge:'b-gray'},
};

function Recompensas(){
  const [sel,setSel]=useState(null);
  const [filtro,setFiltro]=useState('');
  const [modalValidar,setModalValidar]=useState(null);
  const [modalRejeitar,setModalRejeitar]=useState(null);
  const [modalPagar,setModalPagar]=useState(null);
  const [motivoRejeicao,setMotivoRejeicao]=useState('');
  const [empenho,setEmpenho]=useState('');
  const [dotacao,setDotacao]=useState('');
  const [loadingAction,setLoadingAction]=useState(false);

  const lista=RECOMP.filter(r=>!filtro||r.status===filtro);
  const kpi=RECOMP_KPIS||{};

  const doAction=async(url,body,msg)=>{
    setLoadingAction(true);
    try{
      const res=await fetch(API_URL+url,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      if(res.ok){
        alert(msg);
        setModalValidar(null);setModalRejeitar(null);setModalPagar(null);setSel(null);
      }else{
        const err=await res.json().catch(()=>({}));
        alert('Erro: '+(err.detail||res.statusText));
      }
    }catch(e){alert('Erro de conexão: '+e.message);}
    setLoadingAction(false);
  };

  const verDadosPagamento=async(id)=>{
    if(!confirm('⚠️ ATENÇÃO: Acessar dados de pagamento gera um registro no audit log (LGPD).\n\nDeseja continuar?'))return;
    try{
      const res=await fetch(API_URL+'/api/recompensas/'+id+'/dados-pagamento?operador=dashboard_admin');
      if(res.ok){
        const d=await res.json();
        alert(`🔐 Dados de Pagamento (LGPD auditado)\n\n📋 CPF: ${d.cpf||'—'}\n💳 Chave PIX: ${d.chave_pix||'—'}\n📌 Tipo: ${d.tipo_chave_pix||'—'}\n\n⚠️ ${d.aviso||''}`);
      }else{
        const err=await res.json().catch(()=>({}));
        alert('Erro: '+(err.detail||res.statusText));
      }
    }catch(e){alert('Erro de conexão: '+e.message);}
  };

  return(
    <div style={{display:'flex',flexDirection:'column',height:'100%',overflow:'hidden'}}>
      <div className="stat-row">
        {[
          {num:`R$ ${(kpi.total_pago||0).toLocaleString('pt-BR',{minimumFractionDigits:2})}`,lbl:'Total Pago',c:'#4ade80'},
          {num:`R$ ${(kpi.total_aguardando||0).toLocaleString('pt-BR',{minimumFractionDigits:2})}`,lbl:'Aguardando Pgto',c:'#fbbf24'},
          {num:`R$ ${(kpi.total_pendente||0).toLocaleString('pt-BR',{minimumFractionDigits:2})}`,lbl:'Pendente Valid.',c:'#3b82f6'},
          {num:kpi.total_recompensas||RECOMP.length,lbl:'Total Registros',c:'#fff'},
          {num:kpi.pendentes_validacao||RECOMP.filter(r=>r.status==='pendente_validacao').length,lbl:'A Validar',c:'#f59e0b'},
        ].map((s,i)=>(
          <div key={i} className="stat-box anim-card">
            <div className="stat-num" style={{color:s.c}}>{s.num}</div>
            <div className="stat-lbl">{s.lbl}</div>
          </div>
        ))}
      </div>
      <div className="tab-bar">
        <div className="tab active">Recompensas</div>
        <div className="tab-spacer"/>
        <div style={{display:'flex',alignItems:'flex-end',paddingBottom:10,gap:8}}>
          <select value={filtro} onChange={e=>setFiltro(e.target.value)}>
            <option value="">Todos status</option>
            {Object.entries(S_RECOMP).map(([k,v])=><option key={k} value={k}>{v.label}</option>)}
          </select>
        </div>
      </div>
      <div style={{display:'flex',flex:1,overflow:'hidden'}}>
        <div className="scrollable" style={{flex:1}}>
          <table>
            <thead><tr><th>Protocolo</th><th>Cidadão</th><th>Categoria</th><th>Valor</th><th>Status</th><th>Data</th></tr></thead>
            <tbody>
              {lista.map(r=>{
                const sta=S_RECOMP[r.status]||{label:r.status,badge:'b-gray'};
                const den=DEN.find(d=>d.id===r.denuncia_id)||{};
                const cat=CAT_DEN[den.categoria]||{label:den.categoria||'—',icon:'📌',badge:'b-gray'};
                return(
                  <tr key={r.id} onClick={()=>setSel(r)} style={{cursor:'pointer',background:sel?.id===r.id?'rgba(5,150,105,.04)':''}}>
                    <td><span className="mono" style={{fontSize:12,color:'var(--text-muted)'}}>{r.protocolo}</span></td>
                    <td>{den.nome||'—'}</td>
                    <td><span className={`badge ${cat.badge}`}>{cat.icon} {cat.label}</span></td>
                    <td><span className="mono" style={{fontWeight:600,color:'#4ade80'}}>R$ {(r.valor||0).toLocaleString('pt-BR',{minimumFractionDigits:2})}</span></td>
                    <td><span className={`badge ${sta.badge}`}>{sta.label}</span></td>
                    <td style={{color:'var(--text-muted)',fontSize:12}}>{ago(r.created_at)}</td>
                  </tr>
                );
              })}
              {lista.length===0&&<tr><td colSpan={6} style={{textAlign:'center',color:'var(--text-muted)',padding:40}}>Nenhuma recompensa encontrada</td></tr>}
            </tbody>
          </table>
        </div>

        {/* Painel lateral de detalhes */}
        {sel&&(
          <div style={{width:360,borderLeft:'1px solid var(--border)',background:'var(--surface)',display:'flex',flexDirection:'column',flexShrink:0}}>
            <div style={{padding:'16px 20px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
              <span className="mono" style={{fontSize:13,color:'var(--text-muted)'}}>{sel.protocolo}</span>
              <button onClick={()=>setSel(null)} style={{background:'none',border:'none',color:'var(--text-muted)',cursor:'pointer',fontSize:16}}>✕</button>
            </div>
            <div className="scrollable" style={{flex:1,padding:'16px 20px'}}>
              <div style={{display:'grid',gap:10,fontSize:13,marginBottom:20}}>
                {[
                  ['Status',(S_RECOMP[sel.status]||{}).label||sel.status],
                  ['Valor',`R$ ${(sel.valor||0).toLocaleString('pt-BR',{minimumFractionDigits:2})}`],
                  ['Tipo PIX',sel.tipo_chave_pix||'—'],
                  ['Cidadão',(DEN.find(d=>d.id===sel.denuncia_id)||{}).nome||'—'],
                  sel.empenho&&['Empenho',sel.empenho],
                  sel.dotacao_orcamentaria&&['Dotação',sel.dotacao_orcamentaria],
                  sel.motivo_rejeicao&&['Motivo Rejeição',sel.motivo_rejeicao],
                ].filter(Boolean).map(([l,v])=>(
                  <div key={l} style={{display:'flex',justifyContent:'space-between',padding:'10px 14px',background:'rgba(255,255,255,.02)',borderRadius:8,border:'1px solid var(--border)'}}>
                    <span style={{color:'var(--text-muted)'}}>{l}</span>
                    <span style={{fontWeight:500,color:l==='Valor'?'#4ade80':l==='Status'&&sel.status==='paga'?'#4ade80':'var(--text)'}}>{v}</span>
                  </div>
                ))}
              </div>

              <div style={{display:'flex',flexDirection:'column',gap:8}}>
                <button className="btn btn-outline" style={{width:'100%',justifyContent:'center'}} onClick={()=>verDadosPagamento(sel.id)}>🔒 Ver Dados de Pagamento</button>

                {sel.status==='pendente_validacao'&&(
                  <>
                    <button className="btn btn-primary" style={{width:'100%',justifyContent:'center'}} onClick={()=>setModalValidar(sel)}>✓ Validar Recompensa</button>
                    <button className="btn btn-danger" style={{width:'100%',justifyContent:'center'}} onClick={()=>{setMotivoRejeicao('');setModalRejeitar(sel);}}>✕ Rejeitar</button>
                  </>
                )}
                {(sel.status==='validada'||sel.status==='aguardando_pagamento')&&(
                  <button className="btn btn-primary" style={{width:'100%',justifyContent:'center'}} onClick={()=>{setEmpenho('');setDotacao('');setModalPagar(sel);}}>💳 Registrar Pagamento</button>
                )}
                {sel.status==='paga'&&(
                  <a href={API_URL+'/api/recompensas/'+sel.id+'/termo'} target="_blank" className="btn btn-outline" style={{width:'100%',justifyContent:'center',textDecoration:'none'}}>📄 Gerar Termo PDF</a>
                )}
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Modal Validar */}
      {modalValidar&&(
        <div className="modal-overlay" onClick={()=>setModalValidar(null)}>
          <div className="modal-box" style={{maxWidth:400}} onClick={e=>e.stopPropagation()}>
            <div style={{padding:'18px 22px',borderBottom:'1px solid var(--border)'}}>
              <div style={{fontWeight:600,fontSize:16}}>Validar Recompensa</div>
              <div style={{fontSize:13,color:'var(--text-muted)',marginTop:4}}>Protocolo: {modalValidar.protocolo} — R$ {modalValidar.valor?.toLocaleString('pt-BR',{minimumFractionDigits:2})}</div>
            </div>
            <div style={{padding:'18px 22px'}}>
              <p style={{fontSize:13,color:'var(--text-secondary)',marginBottom:16}}>Confirma que a denúncia foi verificada e a recompensa deve ser liberada para pagamento?</p>
              <div style={{display:'flex',gap:10}}>
                <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}} onClick={()=>setModalValidar(null)}>Cancelar</button>
                <button className="btn btn-primary" style={{flex:1,justifyContent:'center'}} disabled={loadingAction}
                  onClick={()=>doAction('/api/recompensas/'+modalValidar.id+'/validar',{operador:'admin',procedente:true},'Recompensa validada com sucesso!')}>
                  {loadingAction?'...':'✓ Confirmar'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Modal Rejeitar */}
      {modalRejeitar&&(
        <div className="modal-overlay" onClick={()=>setModalRejeitar(null)}>
          <div className="modal-box" style={{maxWidth:440}} onClick={e=>e.stopPropagation()}>
            <div style={{padding:'18px 22px',borderBottom:'1px solid var(--border)'}}>
              <div style={{fontWeight:600,fontSize:16}}>Rejeitar Recompensa</div>
              <div style={{fontSize:13,color:'var(--text-muted)',marginTop:4}}>Protocolo: {modalRejeitar.protocolo}</div>
            </div>
            <div style={{padding:'18px 22px'}}>
              <label style={{fontSize:12,color:'var(--text-muted)',display:'block',marginBottom:6}}>Motivo da rejeição *</label>
              <textarea value={motivoRejeicao} onChange={e=>setMotivoRejeicao(e.target.value)} placeholder="Explique o motivo..."
                style={{width:'100%',minHeight:80,padding:10,background:'var(--card)',border:'1px solid var(--border)',borderRadius:8,color:'var(--text)',fontSize:13,resize:'vertical'}}/>
              <div style={{display:'flex',gap:10,marginTop:14}}>
                <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}} onClick={()=>setModalRejeitar(null)}>Cancelar</button>
                <button className="btn btn-danger" style={{flex:1,justifyContent:'center'}} disabled={loadingAction||!motivoRejeicao.trim()}
                  onClick={()=>doAction('/api/recompensas/'+modalRejeitar.id+'/validar',{operador:'admin',procedente:false,motivo_rejeicao:motivoRejeicao},'Recompensa rejeitada.')}>
                  {loadingAction?'...':'✕ Rejeitar'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Modal Pagar */}
      {modalPagar&&(
        <div className="modal-overlay" onClick={()=>setModalPagar(null)}>
          <div className="modal-box" style={{maxWidth:440}} onClick={e=>e.stopPropagation()}>
            <div style={{padding:'18px 22px',borderBottom:'1px solid var(--border)'}}>
              <div style={{fontWeight:600,fontSize:16}}>Registrar Pagamento</div>
              <div style={{fontSize:13,color:'var(--text-muted)',marginTop:4}}>Protocolo: {modalPagar.protocolo} — R$ {modalPagar.valor?.toLocaleString('pt-BR',{minimumFractionDigits:2})}</div>
            </div>
            <div style={{padding:'18px 22px'}}>
              <label style={{fontSize:12,color:'var(--text-muted)',display:'block',marginBottom:6}}>Nº do Empenho *</label>
              <input value={empenho} onChange={e=>setEmpenho(e.target.value)} placeholder="Ex: 2026NE001234"
                style={{width:'100%',padding:10,background:'var(--card)',border:'1px solid var(--border)',borderRadius:8,color:'var(--text)',fontSize:13,marginBottom:12}}/>
              <label style={{fontSize:12,color:'var(--text-muted)',display:'block',marginBottom:6}}>Dotação Orçamentária *</label>
              <input value={dotacao} onChange={e=>setDotacao(e.target.value)} placeholder="Ex: 06.122.0002.2001.339039"
                style={{width:'100%',padding:10,background:'var(--card)',border:'1px solid var(--border)',borderRadius:8,color:'var(--text)',fontSize:13,marginBottom:14}}/>
              <div style={{display:'flex',gap:10}}>
                <button className="btn btn-outline" style={{flex:1,justifyContent:'center'}} onClick={()=>setModalPagar(null)}>Cancelar</button>
                <button className="btn btn-primary" style={{flex:1,justifyContent:'center'}} disabled={loadingAction||!empenho.trim()||!dotacao.trim()}
                  onClick={()=>doAction('/api/recompensas/'+modalPagar.id+'/pagar',{operador:'admin',empenho,dotacao_orcamentaria:dotacao},'Pagamento registrado com sucesso!')}>
                  {loadingAction?'...':'💳 Confirmar Pagamento'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Config de valores - mostra quando nada selecionado */}
      {!sel&&RECOMP_CFG.length>0&&(
        <div style={{position:'absolute',bottom:20,right:20,background:'var(--card)',border:'1px solid var(--border)',borderRadius:12,padding:'14px 18px',fontSize:12,maxWidth:260}}>
          <div style={{fontWeight:600,marginBottom:8,color:'var(--text-muted)',textTransform:'uppercase',letterSpacing:'.5px',fontSize:10}}>Valores por Categoria</div>
          {RECOMP_CFG.filter(c=>c.ativo).map(c=>(
            <div key={c.categoria} style={{display:'flex',justifyContent:'space-between',padding:'4px 0',borderBottom:'1px solid var(--border)'}}>
              <span style={{color:'var(--text-secondary)'}}>{c.categoria.replace('_',' ')}</span>
              <span className="mono" style={{color:'#4ade80',fontWeight:600}}>R$ {c.valor_padrao?.toLocaleString('pt-BR',{minimumFractionDigits:2})}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

/* ─── BUSCA POR PROTOCOLO ─────────────────────────────────────── */
function SearchProtocolo({setAba}){
  const [q,setQ]=useState('');
  const [res,setRes]=useState(null);
  const [err,setErr]=useState(null);
  const [loading,setLoading]=useState(false);
  const [show,setShow]=useState(false);

  const buscar=async()=>{
    const termo=q.trim().toUpperCase();
    if(!termo)return;
    setLoading(true);setErr(null);setRes(null);setShow(true);
    try{
      const r=await fetch(API_URL+'/api/protocolo/'+encodeURIComponent(termo));
      if(r.ok){setRes(await r.json());}
      else if(r.status===404){setErr('Protocolo não encontrado.');}
      else if(r.status===400){setErr('Formato inválido. Use MGA-2026-XXXXX.');}
      else{setErr('Erro ao buscar.');}
    }catch(e){setErr('Erro de conexão.');}
    setLoading(false);
  };

  const canalLabel={denuncia:'📋 Denúncia',ocorrencia:'🚨 Ocorrência',feedback:'💬 Feedback',sos:'🆘 SOS'};
  const abaMap={denuncia:'denuncias',ocorrencia:'ocorrencias',feedback:'feedbacks',sos:'sos'};

  return(
    <>
      <div style={{display:'flex',alignItems:'center',gap:6}}>
        <div style={{position:'relative'}}>
          <input type="text" placeholder="Buscar protocolo..." value={q} onChange={e=>setQ(e.target.value)}
            onKeyDown={e=>e.key==='Enter'&&buscar()}
            style={{width:220,padding:'6px 10px 6px 28px',background:'var(--card)',border:'1px solid var(--border)',borderRadius:8,color:'var(--text)',fontSize:12,outline:'none'}}/>
          <span style={{position:'absolute',left:8,top:'50%',transform:'translateY(-50%)',fontSize:12,opacity:.5}}>🔍</span>
        </div>
        <button onClick={buscar} disabled={loading||!q.trim()}
          style={{padding:'6px 12px',background:'var(--accent)',color:'#fff',border:'none',borderRadius:8,fontSize:12,fontWeight:600,cursor:'pointer',opacity:loading||!q.trim()?0.5:1}}>
          {loading?'...':'Buscar'}
        </button>
      </div>

      {show&&(
        <div className="modal-overlay" onClick={()=>setShow(false)}>
          <div className="modal-box" style={{maxWidth:480}} onClick={e=>e.stopPropagation()}>
            <div style={{padding:'18px 22px',borderBottom:'1px solid var(--border)',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
              <span style={{fontWeight:600,fontSize:16}}>Resultado da Busca</span>
              <button onClick={()=>setShow(false)} style={{background:'none',border:'none',color:'var(--text-muted)',cursor:'pointer',fontSize:18}}>✕</button>
            </div>
            <div style={{padding:'18px 22px'}}>
              {loading&&<div style={{textAlign:'center',padding:30,color:'var(--text-muted)'}}>Buscando...</div>}
              {err&&<div style={{textAlign:'center',padding:20,color:'var(--danger-light)',background:'rgba(239,68,68,.08)',borderRadius:8}}>{err}</div>}
              {res&&(
                <div>
                  <div style={{display:'flex',alignItems:'center',gap:10,marginBottom:16}}>
                    <span className={`badge ${res.canal==='denuncia'?'b-warn':res.canal==='ocorrencia'?'b-red':res.canal==='feedback'?'b-blue':'b-red'}`}>
                      {canalLabel[res.canal]||res.canal}
                    </span>
                    <span className="mono" style={{fontSize:12,color:'var(--text-muted)'}}>{res.protocolo}</span>
                  </div>
                  <div style={{display:'grid',gap:8,fontSize:13,marginBottom:16}}>
                    {[
                      res.dados?.status&&['Status',res.dados.status.replace(/_/g,' ').toUpperCase()],
                      res.dados?.categoria&&['Categoria',res.dados.categoria.replace(/_/g,' ')],
                      res.dados?.nome&&['Cidadão',res.dados.nome],
                      res.dados?.bairro&&['Bairro',res.dados.bairro],
                      res.dados?.mensagem&&['Mensagem',res.dados.mensagem],
                      res.dados?.cidadania_ativa&&['Cidadão Ativo','SIM — Elegível a recompensa'],
                      res.dados?.created_at&&['Data',new Date(res.dados.created_at).toLocaleString('pt-BR')],
                    ].filter(Boolean).map(([l,v])=>(
                      <div key={l} style={{display:'flex',justifyContent:'space-between',padding:'8px 12px',background:'rgba(255,255,255,.02)',borderRadius:8,border:'1px solid var(--border)',gap:12}}>
                        <span style={{color:'var(--text-muted)',flexShrink:0}}>{l}</span>
                        <span style={{fontWeight:500,color:l==='Cidadão Ativo'?'#4ade80':'var(--text)',textAlign:'right'}}>{v}</span>
                      </div>
                    ))}
                  </div>
                  <button className="btn btn-primary" style={{width:'100%',justifyContent:'center'}}
                    onClick={()=>{setAba(abaMap[res.canal]||'central');setShow(false);}}>
                    Ir para aba {canalLabel[res.canal]?.split(' ')[1]||'Central'}
                  </button>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </>
  );
}

/* ─── APP ──────────────────────────────────────────────────────── */
function App(){
  useApiPolling();
  const [aba,setAba]=useState('central');
  const [hora,setHora]=useState(new Date());
  const [mutado,setMutado]=useState(false);
  const sos=SOS.length;
  useEffect(()=>{const t=setInterval(()=>setHora(new Date()),1000);return()=>clearInterval(t);},[]);

  const ABAS=[
    {id:'central',icon:<Ico.grid/>,label:'Painel'},
    {id:'mapa',icon:<Ico.map/>,label:'Mapa'},
    {id:'ocorrencias',icon:<Ico.alert/>,label:'Ocorrências'},
    {id:'denuncias',icon:<Ico.eye/>,label:'Denúncias'},
    {id:'feedbacks',icon:<Ico.chat/>,label:'Feedbacks',badge:FBK.filter(f=>f.prioridade==='critico').length||null},
    {id:'recompensas',icon:<Ico.coin/>,label:'Recompensas',badge:RECOMP.filter(r=>r.status==='pendente_validacao').length||null},
    {id:'sos',icon:<Ico.shield/>,label:'SOS Mulher',badge:sos>0?sos:null},
    {id:'relatorios',icon:<Ico.report/>,label:'Relatórios'},
  ];

  return(
    <div className="app">
      <header className="hdr">
        <div className="logo">
          <Logo/>
          <div className="logo-text">Node <span>Data</span></div>
          <div className="logo-sep"/>
          <span className="logo-sub">Central de Segurança Pública · Maringá‑PR</span>
        </div>
        <div className="hdr-right">
          <SearchProtocolo setAba={setAba}/>
          <div className="status-badge"><div className="status-dot"/>Online</div>
          <div className="clock-area">
            <div className="clock">{hora.toLocaleTimeString('pt-BR')}</div>
            <div className="clock-date">{hora.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'})}</div>
          </div>
          <button className="hdr-btn" onClick={()=>setMutado(!mutado)}>{mutado?'🔇':'🔊'}</button>
        </div>
      </header>

      {sos>0&&(
        <div className="sos-banner" onClick={()=>setAba('sos')}>
          <span style={{fontSize:18}}>🚨</span>
          <div>
            <span className="sos-label">Alerta SOS Mulher Ativo</span>
            <span className="sos-detail">{SOS[0]?.sos_cadastros?.nome} — {SOS[0]?.sos_cadastros?.endereco}</span>
          </div>
          <span style={{fontSize:12,opacity:.7}}>Clique para ver</span>
          <span className="sos-count">{sos} ativo{sos>1?'s':''}</span>
        </div>
      )}

      <div className="body">
        <nav className="sidebar">
          <div className="sidebar-section">Cidade</div>
          {ABAS.map(a=>(
            <button key={a.id} className={`nav-item ${aba===a.id?'active':''}`} onClick={()=>setAba(a.id)}
              style={a.id==='sos'&&sos>0&&aba!==a.id?{background:'rgba(220,38,38,.05)',borderColor:'rgba(220,38,38,.15)',color:'#f87171'}:{}}>
              {a.icon}
              <span>{a.label}</span>
              {a.badge!=null&&<span className="nav-badge">{a.badge}</span>}
            </button>
          ))}
          <div style={{marginTop:'auto'}}>
            <div className="nav-divider"/>
            <div className="sidebar-section">WhatsApp</div>
            {['Denúncias','SOS','Ocorrências'].map(n=>(
              <div key={n} className="ws-row"><div className="ws-dot"/>{n}</div>
            ))}
          </div>
        </nav>
        <main className="content">
          <PageTransition pageKey={aba}>
            {aba==='central'&&<Central sos={sos}/>}
            {aba==='mapa'&&<Mapa/>}
            {aba==='ocorrencias'&&<Ocorrencias/>}
            {aba==='denuncias'&&<Denuncias/>}
            {aba==='feedbacks'&&<Feedbacks/>}
            {aba==='recompensas'&&<Recompensas/>}
            {aba==='sos'&&<SOSMulher/>}
            {aba==='relatorios'&&<Relatorios/>}
          </PageTransition>
        </main>
      </div>
    </div>
  );
}
ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
