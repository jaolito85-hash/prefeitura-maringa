# ============================================================
# NODE DATA MARINGÁ — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env no git!
# ============================================================

# Supabase (encontre em: Project Settings > API)
SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis
REDIS_URL=redis://localhost:6379

# Evolution API (seu servidor de WhatsApp)
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=sua-chave-api-aqui

# Nomes das instâncias WhatsApp (configure no painel da Evolution)
WA_INSTANCE_DENUNCIAS=maringa-denuncias
WA_INSTANCE_SOS=maringa-sos-mulher
WA_INSTANCE_OCORRENCIAS=maringa-ocorrencias

# Segurança
WEBHOOK_SECRET=uma-chave-secreta-bem-longa-aqui
AES_KEY=chave-de-32-bytes-exatamente-aqui!   # Deve ter EXATAMENTE 32 caracteres

# Configuração da aplicação
ENVIRONMENT=development
DEBUG=true
PORT=8000
