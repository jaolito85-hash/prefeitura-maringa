# ============================================================
# BACKEND — Variáveis de Ambiente
# INSTRUÇÕES: Copie este arquivo para .env e preencha os valores
# ATENÇÃO: Nunca compartilhe o arquivo .env — ele fica fora do GitHub!
# ============================================================

# ── Supabase ─────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# ── Redis ─────────────────────────────────────────────────
# Em produção (Coolify), o Redis está no mesmo docker-compose
REDIS_URL=redis://redis:6379

# ── Evolution API (WhatsApp) ─────────────────────────────
EVOLUTION_API_URL=https://sua-evolution.seudominio.com
EVOLUTION_API_KEY=sua-chave-aqui

# Pra demo (número único — IA classifica tudo):
WA_INSTANCE_NAME=maringa-demo

# Pra produção (3 números separados):
WA_INSTANCE_DENUNCIAS=maringa-denuncias
WA_INSTANCE_SOS=maringa-sos-mulher
WA_INSTANCE_OCORRENCIAS=maringa-ocorrencias

# ── Anthropic (Claude API) ────────────────────────────────
# O classificador inteligente usa essa chave pra analisar mensagens
# Pegue em: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Segurança ─────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=gere-uma-chave-aleatoria-aqui
# AES_KEY: chave da criptografia AES-256-GCM de CPF/PIX/dados bancários.
# OBRIGATÓRIA em produção e deve ser FIXA/ESTÁVEL — trocar torna ilegíveis
# os dados sensíveis já gravados. Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AES_KEY=gere-outra-chave-aleatoria-aqui

# ── Aplicação ─────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
PORT=8000
