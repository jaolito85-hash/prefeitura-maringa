# ============================================================
# NODE DATA MARINGÁ — .gitignore
# ============================================================

# Pasta de skills do Cursor (não usamos Cursor neste projeto)
.cursor/

# Dependências Node.js (geradas pelo npm install)
node_modules/

# Variáveis de ambiente — NUNCA commitar esses arquivos!
.env
backend/.env
frontend/.env

# Build do React (gerado pelo npm run build)
frontend/dist/
frontend/build/

# Cache do Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
backend/.venv/

# Cache do sistema operacional
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Arquivos temporários
*.tmp
*.temp

# Ferramentas de IA / agentes (não fazem parte do código do projeto)
.agents/
.claude/
.skills/
.worktrees/
_bmad/
_bmad-output/

# Caches de modelos / virtualenvs externos (não fazem parte do projeto)
.hf-cache/
.external/
.playwright-mcp/
.tmp-pip/
.venv-vibevoice/
.venv-vibevoice-uv/
.venv-wan22/
.vibevoice-packages/

# Artefatos de roteiro e cenas de vídeo
presentation-scenes/
scene-*.png
roteiro-narracao-video.md
prompt-claude-code-*.md

# Lock de skills (artefato CLI)
skills-lock.json

# Screenshots soltos
[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*.png
ruim.png
stitch-reference.png

# Logs http temporários
tmp-http.*.log
